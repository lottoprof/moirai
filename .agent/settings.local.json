{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit -m :*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git restore:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(ls:*)",
      "Bash(ls *)",
      "Bash(find . *)",
      "Bash(find /home/az/git/moirai *)",
      "Bash(grep:*)",
      "Bash(rg -n:*)",
      "Bash(rg :*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(tail -n:*)",
      "Bash(head -n:*)",
      "Bash(sed -n:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm preview:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm create astro:*)",
      "Bash(pnpm exec astro:*)",
      "Bash(pnpm exec astro check:*)",
      "Bash(pnpm exec astro build:*)",
      "Bash(pnpm exec wrangler types:*)",
      "Bash(pnpm exec wrangler --version)",
      "Bash(pnpm wrangler pages dev:*)",
      "Bash(pnpm exec wrangler pages dev:*)",
      "Bash(pnpm exec wrangler pages project list:*)",
      "Bash(pnpm exec wrangler pages deployment list:*)",
      "Bash(pnpm exec wrangler d1 migrations create:*)",
      "Bash(pnpm exec wrangler d1 migrations list * --local)",
      "Bash(pnpm exec wrangler d1 migrations list * --remote)",
      "Bash(pnpm exec wrangler d1 migrations apply * --local)",
      "Bash(pnpm exec wrangler d1 execute * --local *)",
      "Bash(pnpm exec wrangler kv:key list:*)",
      "Bash(pnpm exec wrangler kv:namespace list:*)",
      "Bash(pnpm exec wrangler r2 bucket list:*)",
      "Bash(pnpm exec wrangler r2 object list:*)",
      "Bash(pnpm exec playwright test:*)",
      "Bash(pnpm exec playwright show-report:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(bash scripts/git-hooks/install.sh)",
      "Read(//tmp/**)",
      "WebSearch",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_close",
      "mcp__claude_ai_Cloudflare_Developer_Platform__search_cloudflare_documentation",
      "mcp__claude_ai_Mermaid_Chart__validate_and_render_mermaid_diagram"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Read\" && tool_input.file_path matches \"(\\\\.env$|\\\\.env\\\\..*$|\\\\.dev\\\\.vars$)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCK] Чтение секретов запрещено. Используй wrangler pages secret put / list' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "tool == \"Write\" && tool_input.file_path matches \"(\\\\.env$|\\\\.env\\\\..*$|\\\\.dev\\\\.vars$)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCK] Запись секретов запрещена. Используй wrangler pages secret put' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"(\\\\.env$|\\\\.env\\\\..*$|\\\\.dev\\\\.vars$)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCK] Правка секретов запрещена. Используй wrangler pages secret put' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"(wrangler pages deploy|wrangler d1 execute.*--remote|wrangler d1 migrations apply.*--remote|wrangler pages secret put|wrangler pages secret delete)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCK] Production-операции wrangler требуют явного запроса пользователя.' >&2; exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"Write\" && tool_input.file_path matches \"\\\\.sh$\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash -n \"$TOOL_INPUT_FILE_PATH\" 2>&1 || echo '[WARN] bash -n нашёл проблемы' >&2"
          }
        ]
      }
    ]
  }
}
