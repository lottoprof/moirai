---
/*
 * Корневой layout для всех публичных страниц ([locale]/*.astro).
 * Подключает design tokens, SEO head, skip link, base body shell.
 *
 * Стилизация секций (компонентов Hero/Section/Card и т.д.) —
 * Stage 4. Сейчас body отдаёт чистую семантику без декоративных
 * стилей, чтобы первый билд работал и читался скрин-ридером.
 */

import "../../styles/tokens.css";
import "../../styles/base.css";
import "../../styles/utilities.css";
import SeoHead from "../../components/public/SeoHead.astro";
import Nav from "../../components/public/Nav.astro";
import Footer from "../../components/public/Footer.astro";

interface Seo {
  title: string;
  description: string;
  og_image?: string;
  noindex?: boolean;
}

interface Props {
  locale: "en" | "ru";
  seo: Seo;
}

const { locale, seo } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0D0B09" />
    <meta name="color-scheme" content="dark" />

    <SeoHead locale={locale} pathname={pathname} seo={seo} />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <Nav locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>

<!--
  Глобальные стили вынесены в src/styles/{base,utilities}.css —
  импортируются выше во frontmatter. Per-component scoped styles
  живут в .astro компонентах через <style> (без is:global).
-->
