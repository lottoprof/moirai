---
/*
 * Корневой layout для protected zone — личного кабинета студента.
 * Отличия от public/Layout.astro:
 *   - DashboardNav вместо public Nav (без Sign in/Sign up, без LangSwitcher
 *     в маркетинговом стиле — внутри кабинета locale выбран при логине)
 *   - noindex зашит в layout (защищённая зона всегда noindex)
 *   - без Footer (self-contained зона)
 *
 * Импортирует тот же набор стилей что и public layout — единый source
 * of truth для дизайн-токенов и базовых reset'ов.
 */

import "../../styles/tokens.css";
import "../../styles/fonts.css";
import "../../styles/base.css";
import "../../styles/utilities.css";
import SeoHead from "../../components/public/SeoHead.astro";
import DashboardNav from "../../components/dashboard/DashboardNav.astro";
import type { Role } from "../../../db/types";

interface Seo {
  title: string;
  description: string;
}

interface Props {
  locale: "en" | "ru";
  seo: Seo;
  currentNavKey: "dashboard" | "modules" | "homework" | "account";
  /** Roles user'a для zone-switcher в Nav. Если undefined — switcher
   *  не показывается (страница не передала roles). */
  userRoles?: Set<Role>;
  /** Show drawer hamburger trigger в nav. Default false. Set true
   *  на pages где drawer есть (paid dashboard, module page). */
  showDrawerTrigger?: boolean;
}

const { locale, seo, currentNavKey, userRoles, showDrawerTrigger = false } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0D0B09" />
    <meta name="color-scheme" content="dark" />

    <SeoHead
      locale={locale}
      pathname={pathname}
      seo={{ title: seo.title, description: seo.description, noindex: true }}
    />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <DashboardNav locale={locale} currentKey={currentNavKey} roles={userRoles}
                   showDrawerTrigger={showDrawerTrigger} />

    <div class="dashboard-shell">
      <slot name="drawer" />
      <main id="main" class="dashboard-main">
        <slot />
      </main>
    </div>

    <style>
      .dashboard-shell {
        display: block;
      }
      @media (min-width: 1024px) {
        .dashboard-shell {
          display: grid;
          grid-template-columns: 320px 1fr;
          grid-template-areas: "drawer main";
        }
        .dashboard-shell > main {
          grid-area: main;
        }
      }
    </style>
  </body>
</html>
