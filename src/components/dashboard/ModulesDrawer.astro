---
/*
 * ModulesDrawer — left sidebar/overlay со списком модулей программы.
 *
 * Student LK v2 Stage E/E5.
 *
 * Behaviour:
 *   - Desktop ≥1024: permanent sidebar, toggle через кнопку.
 *   - Mobile/tablet: overlay через hamburger, tap-outside-to-close,
 *     edge swipe.
 *   - localStorage persistence для desktop state.
 *
 * Spec: docs/student-lk-v2-spec.md § 5.3.
 */

import Lock from "../icons/Lock.astro";
import Check from "../icons/Check.astro";
import X from "../icons/X.astro";

interface ModuleItem {
  slug: string;
  title: string;
  orderIdx: number;
  status: "done" | "active" | "locked";
  unlockDate?: string;
}

interface Props {
  locale: "en" | "ru";
  programmeTitle: string;
  modules: ModuleItem[];
  doneCount: number;
  totalCount: number;
  /** Slug текущего открытого модуля — для highlight. Null если на dashboard. */
  currentSlug?: string | null;
}

const { locale, programmeTitle, modules, doneCount, totalCount, currentSlug } = Astro.props;

const labels = locale === "ru"
  ? { progress: (d: number, t: number) => `${d.toString()} из ${t.toString()} пройдено`,
      close: "Закрыть",
      header: "Модули программы" }
  : { progress: (d: number, t: number) => `${d.toString()} of ${t.toString()} done`,
      close: "Close",
      header: "Programme modules" };

const progressPct = totalCount > 0 ? Math.round((doneCount / totalCount) * 100) : 0;
---

<aside class="drawer" id="modules-drawer" data-drawer aria-label={labels.header}>
  <div class="drawer__header">
    <div>
      <p class="drawer__programme">{programmeTitle}</p>
      <p class="drawer__progress">{labels.progress(doneCount, totalCount)}</p>
    </div>
    <button type="button" class="drawer__close" data-drawer-close aria-label={labels.close}>
      <X size={20} />
    </button>
  </div>
  <div class="drawer__progress-bar" aria-hidden="true">
    <div class="drawer__progress-fill" style={`width: ${String(progressPct)}%`}></div>
  </div>

  <ul class="drawer__list" role="list">
    {modules.map((m) => {
      const isCurrent = m.slug === currentSlug;
      return (
        <li class="drawer__item">
          <a
            class:list={["drawer__link", `drawer__link--${m.status}`, isCurrent && "drawer__link--current"]}
            href={m.status !== "locked" ? `/${locale}/dashboard/modules/${m.slug}` : undefined}
            aria-current={isCurrent ? "page" : undefined}
            aria-disabled={m.status === "locked" ? "true" : undefined}
          >
            <span class="drawer__num">{String(m.orderIdx + 1).padStart(2, "0")}</span>
            <span class="drawer__title">{m.title}</span>
            {m.status === "done" && <Check size={14} class="drawer__icon" />}
            {m.status === "locked" && <Lock size={14} class="drawer__icon" />}
          </a>
        </li>
      );
    })}
  </ul>
</aside>

<div class="drawer-backdrop" data-drawer-backdrop hidden></div>

<style>
  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    max-width: 80vw;
    background: var(--bg-elevated);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    z-index: 100;
    transform: translateX(-100%);
    transition: transform var(--duration-normal) var(--ease-out);
    overflow-y: auto;
  }
  .drawer[data-open] {
    transform: translateX(0);
  }
  .drawer__header {
    padding: var(--space-lg) var(--space-lg) var(--space-md);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .drawer__programme {
    font-family: var(--font-display);
    font-size: var(--type-body-lg);
    color: var(--text);
    margin: 0 0 var(--space-2xs);
  }
  .drawer__progress {
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    color: var(--text-faint);
    margin: 0;
    letter-spacing: var(--tracking-wide);
  }
  .drawer__close {
    background: transparent;
    border: none;
    color: var(--text-faint);
    cursor: pointer;
    padding: 4px;
  }
  .drawer__close:hover { color: var(--text); }
  .drawer__progress-bar {
    height: 2px;
    background: var(--border);
    margin: 0;
  }
  .drawer__progress-fill {
    height: 100%;
    background: var(--amber);
    transition: width var(--duration-normal) var(--ease-out);
  }
  .drawer__list {
    list-style: none;
    padding: var(--space-sm) 0;
    margin: 0;
    flex: 1;
  }
  .drawer__item { margin: 0; }
  .drawer__link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    color: var(--text-muted);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .drawer__link[href]:hover {
    background: color-mix(in srgb, var(--paper) 4%, transparent);
  }
  .drawer__link--done { color: var(--text-faint); }
  .drawer__link--locked { color: var(--text-faint); cursor: not-allowed; }
  .drawer__link--current {
    background: var(--amber-faint);
    color: var(--text);
    border-left: 3px solid var(--amber);
    padding-left: calc(var(--space-lg) - 3px);
  }
  .drawer__num {
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    color: var(--text-faint);
    min-width: 24px;
  }
  .drawer__title {
    flex: 1;
    font-size: var(--type-body-sm);
    line-height: 1.3;
  }
  .drawer__icon { flex-shrink: 0; opacity: 0.7; }

  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 99;
  }

  /* Desktop ≥1024: permanent sidebar */
  @media (min-width: 1024px) {
    .drawer {
      position: sticky;
      top: 0;
      transform: translateX(0);
      height: 100vh;
      border-right: 1px solid var(--border);
      grid-area: drawer;
    }
    .drawer-backdrop { display: none !important; }
  }
</style>

<script>
  // Drawer toggle + persistence.
  const drawer = document.querySelector<HTMLElement>("[data-drawer]");
  const backdrop = document.querySelector<HTMLElement>("[data-drawer-backdrop]");
  const closeBtn = document.querySelector<HTMLElement>("[data-drawer-close]");
  // Hamburger triggers могут быть в DashboardNav — global listener.
  const triggers = document.querySelectorAll<HTMLElement>("[data-drawer-trigger]");

  function isDesktop(): boolean {
    return window.matchMedia("(min-width: 1024px)").matches;
  }

  function openDrawer() {
    if (!drawer) return;
    drawer.setAttribute("data-open", "");
    if (!isDesktop() && backdrop) {
      backdrop.hidden = false;
      document.body.style.overflow = "hidden";
    }
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.removeAttribute("data-open");
    if (backdrop) backdrop.hidden = true;
    document.body.style.overflow = "";
  }

  function syncState() {
    if (!drawer) return;
    if (isDesktop()) {
      // Persisted preference (default open).
      const stored = localStorage.getItem("moirai.drawer.open");
      if (stored === "0") {
        drawer.removeAttribute("data-open");
      } else {
        drawer.setAttribute("data-open", "");
      }
    } else {
      drawer.removeAttribute("data-open");
      if (backdrop) backdrop.hidden = true;
    }
  }

  triggers.forEach((t) => {
    t.addEventListener("click", () => {
      if (drawer?.hasAttribute("data-open")) {
        if (isDesktop()) localStorage.setItem("moirai.drawer.open", "0");
        closeDrawer();
      } else {
        if (isDesktop()) localStorage.setItem("moirai.drawer.open", "1");
        openDrawer();
      }
    });
  });

  closeBtn?.addEventListener("click", () => {
    if (isDesktop()) localStorage.setItem("moirai.drawer.open", "0");
    closeDrawer();
  });
  backdrop?.addEventListener("click", closeDrawer);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && drawer?.hasAttribute("data-open") && !isDesktop()) closeDrawer();
  });

  syncState();
  window.addEventListener("resize", syncState);
</script>
