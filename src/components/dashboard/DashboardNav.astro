---
/*
 * Top nav для dashboard зоны. Логотип слева + 4 пункта справа
 * (Dashboard / Modules / Homework / Account). Активный пункт —
 * через `currentKey` prop, подсвечивается amber-цветом и помечается
 * `aria-current="page"`.
 *
 * Sign out живёт на /account странице (мы туда ведём из Account
 * пункта), отдельной кнопки в nav нет — паттерн как у большинства
 * web-приложений.
 *
 * Stub-этап: Modules → /dashboard, Homework → /dashboard (страниц
 * ещё нет, ведём на overview). После Sprint 1 заменятся на реальные
 * URL.
 */

import type { Role } from "../../../db/types";
import Logo from "../shared/Logo.astro";
import List from "../icons/List.astro";

interface Props {
  locale: "en" | "ru";
  currentKey: "dashboard" | "modules" | "homework" | "account";
  /** Дополнительные роли user'a — для zone-switcher. Если undefined,
   *  zone-switcher не рендерится (страница не передала roles). */
  roles?: Set<Role>;
  /** Show drawer hamburger trigger. Default false. */
  showDrawerTrigger?: boolean;
}

const { locale, currentKey, roles, showDrawerTrigger = false } = Astro.props;

const labels = locale === "ru"
  ? {
      aria: "Навигация по личному кабинету",
      dashboard: "Кабинет",
      modules: "Модули",
      homework: "Задания",
      account: "Аккаунт",
      site: "На сайт",
      switchInstructor: "Преподавателю",
      switchAdmin: "Админу",
    }
  : {
      aria: "Dashboard navigation",
      dashboard: "Dashboard",
      modules: "Modules",
      homework: "Homework",
      account: "Account",
      site: "View site",
      switchInstructor: "Instructor",
      switchAdmin: "Admin",
    };

// Stage C: "Homework" link → /dashboard/homework.
// Stage E: "Modules" удалён — drawer заменяет (hamburger trigger в nav).
const items = [
  { key: "dashboard", label: labels.dashboard, href: `/${locale}/dashboard` },
  { key: "homework",  label: labels.homework,  href: `/${locale}/dashboard/homework` },
  { key: "account",   label: labels.account,   href: `/${locale}/account` },
] as const;

// Zone-switcher: показываем links на другие зоны если у user'а
// есть соответствующие роли. См. decisions 2026-05-17 §11.
const otherZones: { href: string; label: string }[] = [];
if (roles?.has("instructor")) {
  otherZones.push({ href: `/${locale}/instructor/`, label: labels.switchInstructor });
}
if (roles?.has("admin")) {
  otherZones.push({ href: `/admin/`, label: labels.switchAdmin });
}
---

<nav class="dashboard-nav" aria-label={labels.aria}>
  <div class="dashboard-nav__brand">
    {showDrawerTrigger && (
      <button type="button" class="dashboard-nav__drawer-trigger" data-drawer-trigger
              aria-label="Toggle modules drawer">
        <List size={20} />
      </button>
    )}
    <a href={`/${locale}/`} class="dashboard-nav__logo" aria-label="Moirai home"><Logo height={26} /></a>
  </div>
  <ul class="dashboard-nav__list" role="list">
    {items.map((item) => (
      <li class="dashboard-nav__item">
        <a
          href={item.href}
          class:list={["dashboard-nav__link", { "dashboard-nav__link--active": item.key === currentKey }]}
          aria-current={item.key === currentKey ? "page" : undefined}
        >{item.label}</a>
      </li>
    ))}
    {otherZones.map((z) => (
      <li class="dashboard-nav__item">
        <a href={z.href} class="dashboard-nav__link dashboard-nav__link--switch">{z.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .dashboard-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-lg) var(--container-pad);
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .dashboard-nav__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-md);
  }
  .dashboard-nav__drawer-trigger {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    align-self: center;
    margin-right: var(--space-xs);
  }
  .dashboard-nav__drawer-trigger:hover { color: var(--text); }
  /* Hide drawer trigger on desktop (drawer is permanent there) */
  @media (min-width: 1024px) {
    .dashboard-nav__drawer-trigger { display: none; }
  }

  .dashboard-nav__logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    opacity: 0.95;
  }

  .dashboard-nav__site {
    font-family: var(--font-body);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .dashboard-nav__site:hover {
    color: var(--text-muted);
  }

  .dashboard-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
    margin: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .dashboard-nav__list::-webkit-scrollbar { display: none; }

  .dashboard-nav__item {
    flex-shrink: 0;
  }

  .dashboard-nav__link {
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: 4px 2px;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .dashboard-nav__link:hover {
    color: var(--text);
  }
  .dashboard-nav__link--active {
    color: var(--text-accent);
  }

  /* Zone-switcher links — приглушены, с отступом для визуального
     отделения от primary nav-items */
  .dashboard-nav__link--switch {
    color: var(--text-faint);
    font-size: var(--type-micro-sm);
    padding-left: var(--space-sm);
    border-left: 1px solid var(--border);
    margin-left: var(--space-xs);
  }
  .dashboard-nav__link--switch:hover {
    color: var(--text-accent);
  }

  @media (max-width: 640px) {
    .dashboard-nav {
      padding: var(--space-md) var(--space-md);
      gap: var(--space-md);
    }
    .dashboard-nav__list {
      gap: var(--space-md);
    }
    .dashboard-nav__link {
      letter-spacing: var(--tracking-wide);
    }
  }
</style>
