---
/*
 * Hero-блок dashboard overview: eyebrow + большое имя + tier-line.
 * Размещается под navbar'ом, отбит снизу разделителем.
 *
 * `name` — first-name (или email-prefix, если name пустой). Очень
 * длинные nick'и (lottoprof) рендерятся через `word-break: break-word`,
 * без <br> внутри слова.
 */

interface Props {
  eyebrow: string;
  name: string;
  tierLine: string;
}

const { eyebrow, name, tierLine } = Astro.props;
---

<header class="dashboard-hero">
  <p class="dashboard-hero__eyebrow">{eyebrow}</p>
  <h1 class="dashboard-hero__title">Hi <span class="dashboard-hero__name">{name}</span>.</h1>
  <p class="dashboard-hero__tier">{tierLine}</p>
</header>

<style>
  .dashboard-hero {
    padding: var(--space-2xl) var(--container-pad) var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .dashboard-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-accent);
    margin-bottom: var(--space-sm);
  }

  .dashboard-hero__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 7vw, 56px);
    font-weight: 400;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin: 0;
    word-break: break-word;
  }

  .dashboard-hero__name {
    /* Слот для длинных имён — позволяем переноситься */
    overflow-wrap: anywhere;
  }

  .dashboard-hero__tier {
    font-family: var(--font-body);
    font-size: var(--type-micro-lg);
    color: var(--text-faint);
    margin-top: var(--space-sm);
    letter-spacing: 0.04em;
  }
</style>
