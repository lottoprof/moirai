---
/*
 * <Btn /> — markup-обёртка для кнопок и CTA-ссылок.
 * Стили живут в `src/styles/utilities.css` (.btn + модификаторы),
 * этот компонент только композирует правильную разметку.
 *
 * Editorial style: text-only (без декоративной стрелки). Affordance
 * через bg color, hover brightness shift. Раньше был `arrow` prop с
 * Unicode "→" — убран (memory feedback_no_unicode_icons + дублирование
 * когда cta_text уже содержал trailing "→"). Prop сохранён как
 * deprecated no-op, чтобы не ломать существующие <Btn arrow>...</Btn>
 * callers до их cleanup.
 *
 * Пример:
 *   <Btn href="/en/apply" variant="primary" size="lg">Apply now</Btn>
 *   <Btn type="submit">Send</Btn>
 */

import type { HTMLAttributes } from "astro/types";

interface Props extends Omit<HTMLAttributes<"a">, "type"> {
  href?: string | URL;
  variant?: "primary" | "ghost";
  size?: "default" | "lg" | "xl";
  type?: "button" | "submit";
  /** Deprecated no-op. Раньше добавлял "→". См. JSDoc выше. */
  arrow?: boolean;
}

const {
  href,
  variant = "primary",
  size = "default",
  type = "button",
  class: extraClass,
  ...rest
} = Astro.props;

const classes = ["btn", `btn--${variant}`];
if (size !== "default") classes.push(`btn--${size}`);
if (typeof extraClass === "string" && extraClass.length > 0) classes.push(extraClass);
const className = classes.join(" ");
---

{
  href ? (
    <a href={href} class={className} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={className} {...rest}>
      <slot />
    </button>
  )
}
