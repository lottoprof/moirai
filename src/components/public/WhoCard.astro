---
/*
 * <WhoCard /> — карточка целевой аудитории в секции "Who is this for".
 * Композируется через `.who-grid` (utilities.css) на странице.
 *
 * Источник CSS: docs/moirai-home.html.
 */

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<article class="who-card">
  <h3 class="who-card__title">{title}</h3>
  <p class="who-card__body">{body}</p>
</article>

<style>
  .who-card__title {
    font-size: var(--type-body-md);
    font-weight: 500;
    color: var(--paper);
    margin-bottom: var(--space-xs);
  }

  .who-card__body {
    font-size: var(--type-body-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
