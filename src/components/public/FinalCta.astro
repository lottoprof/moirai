---
/*
 * <FinalCta /> — финальная CTA-секция перед футером. Сама
 * `<section class="section section--cta">` живёт здесь;
 * `.section--cta` (utilities.css) задаёт центрирование и крупный
 * padding-block.
 *
 * Пульсирующая точка `.urgency__dot` — CSS animation, гасится
 * `prefers-reduced-motion`.
 *
 * Источник CSS: docs/moirai-home.html.
 */

import Btn from "./Btn.astro";

interface Props {
  eyebrow: string;
  /** HTML — допускается <em>/<br> */
  title: string;
  body: string;
  ctaText: string;
  ctaHref: string;
  /** Например "Next cohort starts soon" */
  urgency?: string;
}

const { eyebrow, title, body, ctaText, ctaHref, urgency } = Astro.props;
---

<section class="section section--cta section--alt" aria-labelledby="final-cta-title">
  <p class="eyebrow">{eyebrow}</p>
  <h2 id="final-cta-title" class="final-cta__title h2" set:html={title}></h2>
  <p class="final-cta__lede">{body}</p>
  <Btn href={ctaHref} variant="primary" size="xl" arrow>{ctaText}</Btn>
  {urgency && (
    <p class="urgency">
      <span class="urgency__dot" aria-hidden="true"></span>
      {urgency}
    </p>
  )}
</section>

<style>
  .final-cta__title {
    margin-bottom: var(--space-xl);
  }

  .final-cta__lede {
    font-size: var(--type-body-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-3xl);
    margin-inline: auto;
    max-width: 56ch;
  }

  .urgency {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-2xl);
    font-size: var(--type-micro-md);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .urgency__dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.3);
    }
  }
</style>
