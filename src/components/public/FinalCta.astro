---
/*
 * <FinalCta /> — финальная CTA-секция перед футером. Сама
 * `<section class="section section--cta">` живёт здесь;
 * `.section--cta` (utilities.css) задаёт центрирование и крупный
 * padding-block.
 *
 * Пульсирующая точка `.urgency__dot` — CSS animation, гасится
 * `prefers-reduced-motion`.
 *
 * Источник CSS: docs/moirai-home.html.
 */

import Btn from "./Btn.astro";

interface Props {
  eyebrow: string;
  /** HTML — допускается <em>/<br> */
  title: string;
  body: string;
  ctaText: string;
  ctaHref: string;
  /** Например "Next cohort starts soon" */
  urgency?: string;
}

const { eyebrow, title, body, ctaText, ctaHref, urgency } = Astro.props;
---

<section class="section section--cta" aria-labelledby="final-cta-title">
  <p class="eyebrow">{eyebrow}</p>
  <h2 id="final-cta-title" class="final-cta__title h2" set:html={title}></h2>
  <p class="final-cta__lede">{body}</p>
  {/* Button + urgency inline (как .hero__cta + .hero__urgency).
       Унификация: финальный CTA выглядит как hero CTA — same pattern,
       same expectations. Pulse-dot убран — было дополнительной анимацией
       не вписывающейся в editorial стиль. */}
  <div class="final-cta__action">
    <Btn href={ctaHref} variant="primary" size="xl" arrow>{ctaText}</Btn>
    {urgency && (
      <p class="final-cta__urgency">{urgency}</p>
    )}
  </div>
</section>

<style>
  .final-cta__title {
    margin-bottom: var(--space-xl);
  }

  .final-cta__lede {
    font-size: var(--type-body-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-3xl);
    margin-inline: auto;
    max-width: 56ch;
  }

  /* Action row — button + urgency inline (desktop), wrap на mobile.
     Идентично .hero__cta + .hero__urgency pattern'у. */
  .final-cta__action {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .final-cta__urgency {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--type-body-sm);
    font-family: var(--font-body);
    letter-spacing: var(--tracking-normal);
  }
</style>
