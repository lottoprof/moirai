---
/*
 * <Ticker /> — горизонтальная бегущая строка дисциплин под Hero.
 * Декоративный (aria-hidden), screen readers пропускают.
 *
 * Для бесшовного loop трек содержит items дважды, анимация
 * translateX от 0 до -50% за 40s linear infinite. `prefers-reduced-
 * motion: reduce` останавливает анимацию.
 *
 * Источник CSS: docs/moirai-home.html.
 */

interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<div class="ticker" aria-hidden="true">
  <div class="ticker__track">
    {[...items, ...items].map((item, i) => (
      <>
        {i > 0 && <span class="ticker__sep">·</span>}
        <span>{item}</span>
      </>
    ))}
  </div>
</div>

<style>
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: var(--space-lg) 0;
    white-space: nowrap;
  }

  .ticker__track {
    display: inline-flex;
    gap: var(--space-2xl);
    animation: scroll-x 40s linear infinite;
    font-family: var(--font-display);
    font-size: var(--type-body-lg);
    font-weight: 300;
    font-style: italic;
    color: var(--text-faint);
  }

  .ticker__sep {
    color: var(--amber);
  }

  @keyframes scroll-x {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker__track {
      animation: none;
    }
  }
</style>
