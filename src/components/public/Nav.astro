---
/*
 * <Nav /> — фиксированная навигация на всех публичных страницах.
 * Лого + lang switcher + Sign in / Sign up CTA. Fade-in на ~20px
 * scroll через `.is-scrolled` класс, добавляемый vanilla `<script>`.
 *
 * Стили scoped — Astro прибавит скоуп к `.nav` элементу; runtime
 * toggling `.is-scrolled` совместим со скопом (data-attribute
 * остаётся на элементе).
 *
 * Auth-aware: client JS пытается fetch /api/auth/me и если 200 →
 * переключает Sign in/up на Account link. SSR-default — unauth
 * state (Sign in/up видны), JS убирает flicker когда юзер залогинен.
 *
 * Источник CSS: docs/moirai-home.html.
 */

import LangSwitcher from "./LangSwitcher.astro";
import Logo from "../shared/Logo.astro";

interface Props {
  locale: "en" | "ru";
  pathname: string;
}

const { locale, pathname } = Astro.props;

const labels = locale === "ru"
  ? {
      aria: "Главная",
      signIn: "Войти",
      signUp: "Регистрация",
      admin: "Админ",
      instructor: "Преподаватель",
      dashboard: "Кабинет",
    }
  : {
      aria: "Primary",
      signIn: "Sign in",
      signUp: "Sign up",
      admin: "Admin",
      instructor: "Instructor",
      dashboard: "Dashboard",
    };

// Active state на текущей странице — подсвечивается тот item где
// юзер сейчас находится. Оба item видны всегда (юзер может на /login
// понять что он уже зарегистрирован и переключиться на Sign in,
// и наоборот). Pattern такой же как у LangSwitcher (EN / RU).
const onLogin = pathname === `/${locale}/login` || pathname.startsWith(`/${locale}/login/`);
const onRegister = pathname === `/${locale}/register` || pathname.startsWith(`/${locale}/register/`);
---

<nav class="nav" aria-label={labels.aria}>
  <a href={`/${locale}/`} class="nav__logo" aria-label="MoiraiOnline home"><Logo height={28} /></a>
  <div class="nav__right">
    <LangSwitcher current={locale} pathname={pathname} />

    {/* Unauth state — пара Sign in / Sign up, как LangSwitcher. */}
    <div class="nav__auth js-auth-unauth" role="group" aria-label={labels.aria}>
      <a
        href={`/${locale}/login`}
        class:list={["nav__auth-item", { "is-active": onLogin }]}
        aria-current={onLogin ? "page" : undefined}
      >{labels.signIn}</a>
      <span class="nav__auth-sep" aria-hidden="true">/</span>
      <a
        href={`/${locale}/register`}
        class:list={["nav__auth-item nav__auth-item--register", { "is-active": onRegister }]}
        aria-current={onRegister ? "page" : undefined}
      >{labels.signUp}</a>
    </div>

    {/* Authed state — hidden by default, JS показывает если /api/auth/me OK.
        Из публичного сайта залогиненный пользователь возвращается в свою
        role-home zone (admin > instructor > student priority).
        href + текст обновляются в скрипте после fetchMe(). data-атрибуты
        несут локализованные дефолты — фолбэк если /api/auth/me не вернул roles. */}
    <a
      href={`/${locale}/dashboard`}
      class="nav__cta js-auth-authed"
      hidden
      data-label-admin={labels.admin}
      data-label-instructor={labels.instructor}
      data-label-dashboard={labels.dashboard}
      data-locale={locale}
    >
      {labels.dashboard}
    </a>
  </div>
</nav>

<style>
  /* position: sticky — Nav стакается в normal flow после AnnouncementBar
     (Layout.astro:63-65). До прокрутки бар + nav видны последовательно;
     после прокрутки бар уезжает наверх, nav прилипает к top:0.
     Раньше было position: fixed — это накладывало nav поверх бара,
     ломая верх страницы на mobile (см. screenshot 2026-05-28 18-40-40). */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-lg) var(--container-pad);
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition:
      background var(--duration-normal) var(--ease-out),
      backdrop-filter var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
    border-bottom: 1px solid transparent;
  }

  .nav.is-scrolled {
    background: color-mix(in srgb, var(--ink) 85%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--border);
  }

  .nav__right {
    display: inline-flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.95;
  }

  /* Auth pair (Sign in / Sign up) — паттерн как LangSwitcher: оба
     item видны всегда, current page подсвечивается через .is-active. */
  .nav__auth {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  .nav__auth-item {
    color: var(--text-muted);
    padding: 2px 4px;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }
  .nav__auth-item:hover {
    color: var(--amber);
  }
  .nav__auth-item:active {
    opacity: 0.7;
  }
  .nav__auth-item.is-active {
    color: var(--paper);
  }
  .nav__auth-sep {
    color: var(--text-faint);
  }

  /* Primary CTA (Account — для залогиненного юзера) — amber underline */
  .nav__cta {
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--amber);
    border-bottom: 1px solid var(--amber);
    padding-bottom: 2px;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }
  .nav__cta:hover {
    color: var(--amber-light);
    border-bottom-color: var(--amber-light);
  }
  .nav__cta:active {
    opacity: 0.7;
  }

  /* JS toggle handles via .hidden attribute */
  [hidden] { display: none !important; }

  /* Mobile (<=640px): скрываем "/ Sign up" — остаётся один Sign in.
     Регистрация достижима через ссылку "No account? Create one"
     на /login странице (login.astro:186). */
  @media (max-width: 640px) {
    .nav__auth-sep,
    .nav__auth-item--register {
      display: none;
    }
    .nav {
      padding: var(--space-md) var(--container-pad);
    }
    .nav__right {
      gap: var(--space-md);
    }
  }
</style>

<script>
  /*
   * Auth-aware nav toggle.
   * - Сначала default state: Sign in / Sign up видны.
   * - Если access token в sessionStorage — пробуем /api/auth/me.
   *   200 → показываем Account, прячем unauth links.
   *   401/expired → пробуем refresh, потом ещё раз me. Если опять
   *   неуспех — остаёмся в unauth state.
   *
   * + scroll-fade nav background (как раньше).
   */
  const nav = document.querySelector(".nav");
  if (nav instanceof HTMLElement) {
    const updateScroll = (): void => {
      nav.classList.toggle("is-scrolled", window.scrollY > 20);
    };
    updateScroll();
    window.addEventListener("scroll", updateScroll, { passive: true });
  }

  interface MeUser {
    roles?: string[];
    locale?: string;
  }
  interface MeResponse {
    user?: MeUser;
  }

  async function fetchMe(token: string | null): Promise<MeUser | null> {
    const headers: Record<string, string> = {};
    if (token) headers.Authorization = `Bearer ${token}`;
    const res = await fetch("/api/auth/me", {
      method: "GET",
      headers,
      credentials: "same-origin",
    });
    if (!res.ok) return null;
    try {
      const data = (await res.json()) as MeResponse;
      return data.user ?? null;
    } catch {
      return null;
    }
  }

  /** admin > instructor > student priority — синхронно с roleHomeUrl на сервере. */
  function pickRoleHome(roles: string[] | undefined, locale: string): { href: string; key: "admin" | "instructor" | "dashboard" } {
    const set = new Set(roles ?? []);
    if (set.has("admin")) return { href: "/admin/", key: "admin" };
    if (set.has("instructor")) return { href: `/${locale}/instructor/`, key: "instructor" };
    return { href: `/${locale}/dashboard/`, key: "dashboard" };
  }

  async function tryRefresh(): Promise<string | null> {
    const res = await fetch("/api/auth/refresh", {
      method: "POST",
      credentials: "same-origin",
      headers: { "Content-Type": "application/json" },
    });
    if (!res.ok) return null;
    try {
      const data = (await res.json()) as { access_token?: string };
      if (data.access_token) {
        sessionStorage.setItem("moirai_access_token", data.access_token);
        return data.access_token;
      }
    } catch { /* ignore */ }
    return null;
  }

  async function syncAuthUI() {
    let token = sessionStorage.getItem("moirai_access_token");
    let me: MeUser | null = null;
    if (token) {
      me = await fetchMe(token);
    }
    if (!me) {
      // Может быть refresh cookie живой — попытка обновить access.
      // refresh endpoint возвращает 200 { ok: false } на missing cookie
      // (а не 401), чтобы не плодить console errors для анонимных visits.
      token = await tryRefresh();
      if (token) me = await fetchMe(token);
    }

    const unauthEls = document.querySelectorAll<HTMLElement>(".js-auth-unauth");
    const authedEls = document.querySelectorAll<HTMLAnchorElement>(".js-auth-authed");

    if (me) {
      unauthEls.forEach((el) => { el.hidden = true; });
      authedEls.forEach((el) => {
        const navLocale = el.dataset.locale ?? "en";
        const { href, key } = pickRoleHome(me.roles, navLocale);
        el.href = href;
        const labelAttr = `label${key.charAt(0).toUpperCase()}${key.slice(1)}` as "labelAdmin" | "labelInstructor" | "labelDashboard";
        const label = el.dataset[labelAttr];
        if (label) el.textContent = label;
        el.hidden = false;
      });
    } else {
      // default state остаётся (unauth visible) — ничего не меняем
      sessionStorage.removeItem("moirai_access_token");
    }
  }

  syncAuthUI();
</script>
