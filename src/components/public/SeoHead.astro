---
/*
 * SEO-блок head'а для всех публичных страниц.
 * Источник: docs/Home_page_SEO.md §3 (canonical/hreflang),
 * §4 (title/description), §7-8 (Schema.org placeholder, OG/Twitter).
 *
 * Schema.org JSON-LD блоки (EducationalOrganization, Course, Person,
 * FAQPage) — отдельные компоненты, монтируются вызывающей страницей
 * вокруг этого SeoHead. Stage 6 (см. plans/active/sprint0-stage3...).
 */

const SITE = "https://moiraionline.pro";
const MEDIA_BASE = "https://media.moiraionline.pro";
const LOCALES = ["en", "ru"] as const;
type Locale = (typeof LOCALES)[number];

interface Seo {
  title: string;
  description: string;
  og_image?: string;
  noindex?: boolean;
}

interface Props {
  locale: Locale;
  pathname: string;
  seo: Seo;
}

const { locale, pathname, seo } = Astro.props;

const canonical = `${SITE}${pathname}`;

/** Replace locale prefix in path. /en/foo → /ru/foo */
function altPath(targetLocale: Locale): string {
  for (const loc of LOCALES) {
    if (pathname === `/${loc}` || pathname.startsWith(`/${loc}/`)) {
      return `/${targetLocale}${pathname.slice(loc.length + 1)}`;
    }
  }
  return `/${targetLocale}/`;
}

const ogImageUrl = seo.og_image ? `${MEDIA_BASE}/${seo.og_image}` : undefined;

const ogLocaleMap: Record<Locale, string> = { en: "en_US", ru: "ru_RU" };
const ogLocale = ogLocaleMap[locale];
const ogLocaleAlternate = LOCALES
  .filter((l) => l !== locale)
  .map((l) => ogLocaleMap[l]);

const robotsContent = seo.noindex
  ? "noindex, follow"
  : "index, follow, max-image-preview:large";
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />

<link rel="canonical" href={canonical} />

{LOCALES.map((loc) => (
  <link rel="alternate" hreflang={loc} href={`${SITE}${altPath(loc)}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${SITE}${altPath("en")}`} />

<meta name="robots" content={robotsContent} />

{/* Open Graph */}
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Moirai" />
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternate.map((loc) => (
  <meta property="og:locale:alternate" content={loc} />
))}
<meta property="og:url" content={canonical} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
{ogImageUrl && (
  <Fragment>
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.title} />
  </Fragment>
)}

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
