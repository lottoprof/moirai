---
/*
 * <LangSwitcher /> — переключатель локалей.
 *
 * Используется в публичном <Nav /> (mode='public') и в protected
 * зонах admin/instructor/student через <ZoneNav /> / <DashboardNav />
 * (mode='zone').
 *
 * Pathname rewrite:
 *   - /{en|ru}/X → /{другая-локаль}/X (public + student/instructor/account)
 *   - /admin/X — нет локали в URL, target остаётся = pathname,
 *     JS форсит reload после смены user.locale.
 *
 * Mode='public': только cookie `locale_pref` + браузерная навигация.
 * Mode='zone':  cookie + POST /api/account/locale (DB user.locale) +
 *               reload/navigate. См. /pages/api/account/locale.ts.
 *
 * Цвета — CSS-vars с дефолтами под публичный hero. Зоны переопределяют
 * --lang-switcher-color/-hover/-menu-color для muted-палитры.
 */

interface Props {
  current: "en" | "ru";
  pathname: string;
  mode?: "public" | "zone";
}

const { current, pathname, mode = "public" } = Astro.props;

const hasLocalePrefix = /^\/(en|ru)(\/|$)/.test(pathname);
const stripped = pathname.replace(/^\/(en|ru)(\/|$)/, "/");
const target = (locale: "en" | "ru"): string => {
  if (!hasLocalePrefix) return pathname;
  return stripped === "/" || stripped === "" ? `/${locale}/` : `/${locale}${stripped}`;
};

const items: { code: "en" | "ru"; label: string }[] = [
  { code: "en", label: "EN" },
  { code: "ru", label: "RU" },
];

const currentItem = items.find((i) => i.code === current) ?? items[0];
const altItems = items.filter((i) => i.code !== current);

const ariaLabel = current === "ru" ? "Выбор языка" : "Switch language";
---

<details class="lang-switcher" data-mode={mode}>
  <summary class="lang-switcher__toggle" aria-label={ariaLabel}>
    <span>{currentItem.label}</span>
  </summary>
  <ul class="lang-switcher__menu" role="menu">
    {altItems.map((item) => (
      <li role="none">
        <a
          role="menuitem"
          href={target(item.code)}
          class="lang-switcher__item"
          hreflang={item.code}
          lang={item.code}
          data-locale={item.code}
        >{item.label}</a>
      </li>
    ))}
  </ul>
</details>

<style>
  .lang-switcher {
    position: relative;
    display: inline-block;
  }

  .lang-switcher__toggle {
    list-style: none;
    cursor: pointer;
    color: var(--lang-switcher-color, var(--paper));
    padding: 2px 4px;
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out);
    user-select: none;
  }
  .lang-switcher__toggle::-webkit-details-marker { display: none; }
  .lang-switcher__toggle::marker { content: ""; }

  .lang-switcher__toggle:hover {
    color: var(--lang-switcher-hover, var(--amber));
  }
  .lang-switcher__toggle:active {
    opacity: 0.7;
  }
  .lang-switcher[open] .lang-switcher__toggle {
    color: var(--lang-switcher-hover, var(--amber));
  }

  .lang-switcher__menu {
    position: absolute;
    top: calc(100% + var(--space-xs));
    right: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    list-style: none;
    margin: 0;
    padding: var(--space-2xs);
    min-width: 56px;
    z-index: 50;
  }

  .lang-switcher__item {
    display: block;
    padding: var(--space-xs) var(--space-sm);
    color: var(--lang-switcher-menu-color, var(--text-muted));
    text-decoration: none;
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    text-align: center;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .lang-switcher__item:hover {
    color: var(--lang-switcher-hover, var(--amber));
  }
  .lang-switcher__item:active {
    opacity: 0.7;
  }
</style>

<script>
  /*
   * JS поведение:
   *   - cookie save (locale_pref, 1 год) при клике на alt-locale.
   *   - mode='zone': POST /api/account/locale (DB user.locale) + force
   *     reload, если href === current URL (admin path). Иначе follow href.
   *   - mode='public': дефолтный browser-navigate.
   *   - click-outside / Escape → close.
   */
  const switchers = document.querySelectorAll<HTMLDetailsElement>(".lang-switcher");
  switchers.forEach((switcher) => {
    const mode = switcher.dataset.mode ?? "public";

    // Position dropdown menu в viewport-fixed координатах, чтобы
    // overflow:auto ancestor (mobile-scroll list в protected nav) не
    // клипал. Считаем top/right относительно summary при open.
    const summary = switcher.querySelector<HTMLElement>(".lang-switcher__toggle");
    const menu = switcher.querySelector<HTMLElement>(".lang-switcher__menu");
    const positionMenu = (): void => {
      if (!summary || !menu) return;
      const rect = summary.getBoundingClientRect();
      menu.style.position = "fixed";
      menu.style.top = `${rect.bottom + 6}px`;
      menu.style.right = `${window.innerWidth - rect.right}px`;
      menu.style.left = "auto";
    };
    switcher.addEventListener("toggle", () => {
      if (switcher.open) positionMenu();
    });
    window.addEventListener("resize", () => {
      if (switcher.open) positionMenu();
    });

    switcher.querySelectorAll<HTMLAnchorElement>(".lang-switcher__item").forEach((a) => {
      a.addEventListener("click", async (e) => {
        const locale = a.dataset.locale;
        if (locale !== "en" && locale !== "ru") return;

        document.cookie = `locale_pref=${locale}; path=/; max-age=31536000; samesite=lax; secure`;

        if (mode === "zone") {
          e.preventDefault();
          try {
            await fetch("/api/account/locale", {
              method: "POST",
              credentials: "same-origin",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ locale }),
            });
          } catch { /* network failure — fallback на reload, cookie всё равно стоит */ }

          const href = a.getAttribute("href") ?? "";
          const currentPath = window.location.pathname;
          if (href === currentPath || href === currentPath + window.location.search) {
            window.location.reload();
          } else {
            window.location.href = href;
          }
        }
      });
    });

    document.addEventListener("click", (e) => {
      if (!switcher.contains(e.target as Node)) {
        switcher.open = false;
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") switcher.open = false;
    });
  });
</script>
