---
/*
 * <Hero /> — герой-секция публичной главной (LCP элемент).
 *
 * Контент приходит пропами (Content Collection home.{locale}.mdx →
 * sections.hero). Заголовок ожидает HTML (содержит <em>...</em>) —
 * рендерится через set:html.
 *
 * Stagger reveal: eyebrow / title / lede / cta входят с задержками
 * 0.2 / 0.35 / 0.5 / 0.65s. `prefers-reduced-motion: reduce`
 * глобально гасится через base.css/tokens.css.
 *
 * Источник CSS: docs/moirai-home.html.
 */

import Btn from "./Btn.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  eyebrow: string;
  /** HTML — допускается <em> для амбер-акцента */
  title: string;
  lede: string;
  ctaText: string;
  ctaHref: string;
  /** Static fine-print под CTA: cohort/scheduled даты. См. ROADMAP — Sprint 2
      ssg-sync из D1 cohorts заменит manual edit в home.{locale}.mdx. */
  cohortUrgency?: string;
  /** Локаль для возможных будущих локалезависимых элементов hero. */
  locale?: "en" | "ru";
  /** Optional background image. Renders absolute inset:0, brightness 0.30,
      behind content z-index. alt="" — декоративный фон по WCAG H67. */
  bgImage?: ImageMetadata;
}

const { eyebrow, title, lede, ctaText, ctaHref, cohortUrgency, bgImage } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  {bgImage && (
    <div class="hero__bg" aria-hidden="true">
      <Image
        src={bgImage}
        alt=""
        widths={[768, 1200, 1600, 2000, 2560]}
        sizes="100vw"
        format="webp"
        quality={75}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  )}
  {/* Content в inner-container: hero сам full-bleed (bg image идёт
       edge-to-edge как photo-strips), content же ограничен container-max
       + container-pad — единый pattern с остальными секциями. */}
  <div class="hero__inner">
    {/* eyebrow:
         desktop — статичный, центрированный (align-self: center);
         mobile — ticker, бегущая строка (дубль для бесшовного loop'a).
         Дубль скрыт от AT через aria-hidden — читается только первый. */}
    <div class="hero__eyebrow-wrap">
      <span class="hero__eyebrow eyebrow">{eyebrow}</span>
      <span class="hero__eyebrow eyebrow hero__eyebrow--ghost" aria-hidden="true">{eyebrow}</span>
    </div>
    <h1 id="hero-title" class="hero__title h1" set:html={title}></h1>
    <p class="hero__lede text-muted">{lede}</p>
    <div class="hero__cta">
      <Btn href={ctaHref} variant="primary" size="lg" arrow>{ctaText}</Btn>
      {cohortUrgency && (
        <p class="hero__urgency">{cohortUrgency}</p>
      )}
    </div>
  </div>
</section>

<style>
  /* Hero — full-bleed как photo-strips: bg image идёт edge-to-edge.
     Content в .hero__inner с тем же container-max + container-pad
     pattern что и другие секции (.center utility). Источник: пример
     клиента Film_Site_6.html §.hero (padding 80px 60px full-bleed).

     min-height: auto — hero ужимается под content + padding (без пустого
     "100vh"-space внизу), PromoStrip flush с hero. justify-content:
     flex-start + small padding-top → content прижимается к sticky-nav. */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: clamp(40px, 5vw, 64px) var(--container-pad) clamp(40px, 5vw, 64px);
    width: 100%;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  /* Bg image — absolute inset:0 relative to .hero (теперь full-bleed),
     brightness(.30) затемнение для читаемости text поверх.
     Источник CSS: Film_Site_6.html §.hero-img-bg. */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: brightness(0.30);
  }

  .hero__eyebrow-wrap {
    align-self: center;
    margin-bottom: var(--space-2xl);
    opacity: 0;
    animation: rise var(--duration-rise) 0.2s var(--ease-out) both;
    max-width: 100%;
  }
  .hero__eyebrow {
    /* На desktop wrap содержит один span (второй ghost спрятан) — обычная
       inline-block надпись. На mobile активируется ticker (см. ниже). */
    white-space: normal;
  }
  .hero__eyebrow--ghost {
    display: none;
  }

  @media (max-width: 640px) {
    /* Ticker: контейнер обрезает overflow, два eyebrow-span'a выстраиваются
       в ряд и сдвигаются на -50% за 22s по линейному easing'у. Дубль
       нужен для бесшовного loop'a (когда первый ушёл слева, второй уже
       занимает экран). */
    .hero__eyebrow-wrap {
      align-self: stretch;
      width: 100%;
      overflow: hidden;
      display: flex;
      flex-wrap: nowrap;
      gap: var(--space-2xl);
    }
    .hero__eyebrow {
      flex-shrink: 0;
      white-space: nowrap;
      animation: hero-eyebrow-ticker 22s linear infinite;
    }
    .hero__eyebrow--ghost {
      display: inline-block;
    }
  }

  @keyframes hero-eyebrow-ticker {
    from { transform: translateX(0); }
    /* -100% сдвигает на ширину одного span'a + gap — за это время дубль
       занимает позицию первого, loop незаметный. */
    to   { transform: translateX(calc(-100% - var(--space-2xl))); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow {
      animation: none;
    }
  }

  .hero__title {
    margin-bottom: var(--space-2xl);
    max-width: 14ch;
    opacity: 0;
    animation: rise var(--duration-rise) 0.35s var(--ease-out) both;
  }

  .hero__lede {
    font-size: var(--type-body-lg);
    max-width: 56ch;
    margin-bottom: var(--space-3xl);
    opacity: 0;
    animation: rise var(--duration-rise) 0.5s var(--ease-out) both;
  }

  .hero__cta {
    opacity: 0;
    animation: rise var(--duration-rise) 0.65s var(--ease-out) both;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
  /* Fine-print рядом/под кнопкой APPLY. На desktop — справа от кнопки;
     на mobile (flex-wrap) — переносится на новую строку, прижата к началу. */
  .hero__urgency {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--type-body-sm);
    font-family: var(--font-body);
    letter-spacing: var(--tracking-normal);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
