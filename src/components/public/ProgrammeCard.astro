---
/*
 * <ProgrammeCard /> — большая карточка уровня программы
 * (Beginner / Intermediate) в секции Curriculum. Hover: рамка
 * amber + расширение gap у ссылки.
 *
 * Композируется внутри `<div class="programme-grid">` (utilities.css).
 *
 * Источник CSS: docs/moirai-home.html.
 */

interface Props {
  /** Например "Level 01" или "Полная программа" */
  label: string;
  title: string;
  lede: string;
  linkHref: string;
  linkText: string;
  /** Опц. — meta-строка под lede (modules count · lessons · price). */
  meta?: string;
  /** Опц. — массив треков для chips ("Directing", "Editing"...). Берётся
      из sections.curriculum.levels[].tracks (см. home.mdx). Даёт editorial
      depth подобно §.tracks в примере клиента (Film_Site_6.html), но
      сохраняет SEO/CTA структуру programme-card (3 internal deep links +
      pricing inline). */
  tracks?: string[];
}

const { label, title, lede, linkHref, linkText, meta, tracks } = Astro.props;
const hasTracks = (tracks ?? []).length > 0;
---

<article class="programme-card">
  <div class="programme-card__label">{label}</div>
  <h3 class="programme-card__title">{title}</h3>
  <p class="programme-card__lede">{lede}</p>
  {hasTracks && (
    <ul class="programme-card__tracks" role="list">
      {tracks?.map((t) => (
        <li class="programme-card__track">{t}</li>
      ))}
    </ul>
  )}
  {meta && <p class="programme-card__meta">{meta}</p>}
  <a href={linkHref} class="programme-card__link">{linkText}</a>
</article>

<style>
  .programme-card {
    background: var(--bg-elevated);
    padding: var(--space-2xl);
    border: 1px solid var(--border);
    transition: border-color var(--duration-normal) var(--ease-out);
  }
  .programme-card:hover {
    border-color: var(--amber);
  }

  .programme-card__label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: var(--space-md);
  }

  .programme-card__title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .programme-card__lede {
    color: var(--text-muted);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .programme-card__meta {
    color: var(--text-faint);
    font-size: var(--type-micro-md);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xl);
  }

  /* Tracks chips — editorial depth внутри карточки. List-style none,
     каждый chip — pill с тонким border'ом, amber акцент на hover. */
  .programme-card__tracks {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }
  .programme-card__track {
    display: inline-block;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: var(--type-micro-md);
    color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: 500;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .programme-card:hover .programme-card__track {
    border-color: color-mix(in srgb, var(--amber) 40%, transparent);
    color: var(--text);
  }

  /* Link использует text-decoration вместо border-bottom — wraps
     корректно на mobile (длинное "Explore Beginner + Intermediate"
     ломалось при inline-flex + border-bottom: underline только под
     последнюю строку). Текущий text-decoration делает underline
     per line автоматически. */
  .programme-card__link {
    display: inline;
    font-size: var(--type-micro-lg);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--amber);
    text-decoration: underline;
    text-decoration-color: var(--amber);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition:
      text-underline-offset var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }
  .programme-card__link:hover {
    text-underline-offset: 6px;
  }
  .programme-card__link:active {
    opacity: 0.7;
  }

  /* Mobile: меньше font + tighter letter-spacing, чтобы "Explore
     Beginner + Intermediate" компактнее переносился. */
  @media (max-width: 640px) {
    .programme-card__link {
      font-size: var(--type-micro-md);
      letter-spacing: var(--tracking-normal);
    }
  }
</style>
