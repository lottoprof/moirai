---
/*
 * <AiModule /> — slim banner про будущий AI-модуль.
 *
 * Stage 24h: ранее был большой центральный card (~30vh). Конвертирован
 * в тонкий announcement-style баннер (~96px высоты, amber-strip border),
 * чтобы не перегружать главную для Coming-Soon фичи.
 *
 * Composition: компонент сам по себе — `<section>`. На странице
 * рендерится без обёртки `.section`.
 */

interface Props {
  /** Текст бейджа — "Coming Soon" / "Скоро" */
  badge: string;
  /** Заголовок: одна короткая фраза */
  title: string;
  /** Подзаголовок: одна строка, дополняет заголовок */
  body: string;
  ctaText: string;
  ctaHref: string;
}

const { badge, title, body, ctaText, ctaHref } = Astro.props;
---

<section class="ai-banner" aria-label={title}>
  <div class="ai-banner__inner">
    <span class="ai-banner__badge">{badge}</span>
    <h2 class="ai-banner__title">{title}</h2>
    <span class="ai-banner__sep" aria-hidden="true">·</span>
    <p class="ai-banner__body">{body}</p>
    <a href={ctaHref} class="ai-banner__cta">
      {ctaText} <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .ai-banner {
    /* Outer — только container-pad для горизонтальной симметрии с остальной
       страницей. Визуальная "полоска" (бэкграунд + амбер бордеры) ушла
       внутрь inner, ограниченного container-max. */
    padding-block: var(--space-md);
    padding-inline: var(--container-pad);
  }

  .ai-banner__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    background: var(--bg-elevated);
    border-top: 1px solid color-mix(in srgb, var(--amber) 35%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--amber) 35%, transparent);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .ai-banner__badge {
    display: inline-block;
    padding: 4px 10px;
    background: var(--amber-faint);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--amber) 30%, transparent);
    border-radius: 2px;
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-banner__title {
    font-family: var(--font-display);
    font-size: var(--type-body-lg);
    font-weight: 400;
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    letter-spacing: var(--tracking-tight);
  }

  .ai-banner__sep {
    color: var(--amber);
    font-size: var(--type-body-md);
  }

  .ai-banner__body {
    color: var(--text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.4;
    margin: 0;
  }

  .ai-banner__cta {
    margin-left: var(--space-md);
    color: var(--amber);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .ai-banner__cta:hover {
    color: var(--amber-light);
  }

  @media (max-width: 640px) {
    .ai-banner {
      padding-block: var(--space-sm);
      padding-inline: var(--space-md);
    }
    .ai-banner__inner {
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }
    .ai-banner__sep {
      display: none;
    }
    .ai-banner__body {
      flex-basis: 100%;
      text-align: center;
    }
    .ai-banner__cta {
      margin-left: 0;
    }
  }
</style>
