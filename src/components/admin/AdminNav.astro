---
/*
 * Top nav для Admin panel. Без локали в путях, но локаль в UI-строках.
 * + zone-switcher если у admin'а есть instructor/student роли.
 *
 * Структура и стили — общий <ZoneNav /> (Stage 24): один источник
 * истины для admin/instructor nav layout, чтобы шапки не разъезжались
 * визуально при правках.
 */

import type { Role } from "../../../db/types";
import ZoneNav from "../shared/ZoneNav.astro";

interface Props {
  locale: "en" | "ru";
  currentKey: "overview" | "users" | "applications" | "enrollments" | "modules" | "instructors" | "account";
  roles?: Set<Role>;
}

const { locale, currentKey, roles } = Astro.props;

const labels = locale === "ru"
  ? {
      aria: "Навигация админа",
      overview: "Обзор",
      users: "Пользователи",
      applications: "Заявки",
      enrollments: "Записи",
      modules: "Модули",
      instructors: "Преподаватели",
      account: "Аккаунт",
      switchInstructor: "Преподавателю",
      switchDashboard: "Кабинет",
    }
  : {
      aria: "Admin navigation",
      overview: "Overview",
      users: "Users",
      applications: "Applications",
      enrollments: "Enrollments",
      modules: "Modules",
      instructors: "Instructors",
      account: "Account",
      switchInstructor: "Instructor",
      switchDashboard: "Dashboard",
    };

const items = [
  { key: "overview",     label: labels.overview,     href: `/admin/` },
  { key: "users",        label: labels.users,        href: `/admin/users` },
  { key: "applications", label: labels.applications, href: `/admin/applications` },
  { key: "enrollments",  label: labels.enrollments,  href: `/admin/calendar` },
  { key: "modules",      label: labels.modules,      href: `/admin/modules` },
  { key: "instructors",  label: labels.instructors,  href: `/admin/instructors` },
  { key: "account",      label: labels.account,      href: `/${locale}/account` },
];

const otherZones: { href: string; label: string }[] = [];
if (roles?.has("instructor")) {
  otherZones.push({ href: `/${locale}/instructor/`, label: labels.switchInstructor });
}
if (roles?.has("student")) {
  otherZones.push({ href: `/${locale}/dashboard/`, label: labels.switchDashboard });
}
---

<ZoneNav
  brandHref={`/${locale}/`}
  brandAriaLabel="Moirai home"
  ariaLabel={labels.aria}
  items={items}
  currentKey={currentKey}
  otherZones={otherZones}
/>
