---
/*
 * <Logo /> — Moirai wordmark с reel-monogram вместо "M".
 *
 * Дизайн: M (Cormorant 70) + reel-monogram (paths inherit currentColor)
 *         + irai (Cormorant 70) + dot (amber фиксированный).
 *
 * Theme-adaptive через `currentColor` — parent элемент задаёт `color`,
 * SVG наследует. Точка `.` всегда amber #D4820A (brand accent).
 *
 * Cross-zone компонент: используется во всех Nav (public/dashboard/
 * instructor/admin). Live в `src/components/shared/` — единственная
 * зона разрешённая для импорта из ВСЕХ слоёв (cм. boundaries.md).
 *
 * Источник: docs/Architecture.md §brand, public/logo.svg (vector asset).
 */

interface Props {
  /** Высота SVG в пикселях. Width вычисляется по aspect (340:90 ≈ 3.78). */
  height?: number;
  /** ARIA-label для screen reader. По умолчанию "MoiraiOnline".
   *  Note: визуальный SVG wordmark пока читается как "Moirai." — редизайн
   *  wordmark для полного соответствия — Phase 2. */
  label?: string;
  /** Дополнительный class на root <svg>. */
  class?: string;
}

const { height = 24, label = "MoiraiOnline", class: className = "" } = Astro.props;
const width = Math.round((height * 340) / 90);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 340 90"
  width={width}
  height={height}
  role="img"
  aria-label={label}
  class:list={["logo", className]}
>
  {/* M letter — inherits currentColor */}
  <text x="4" y="74"
        font-family="'Cormorant Garamond', 'Cormorant Fallback', Georgia, serif"
        font-size="70" font-weight="300"
        fill="currentColor">M</text>

  {/* Reel monogram — inherits currentColor */}
