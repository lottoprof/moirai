  </g>

  {/* irai */}
  <text x="108" y="74"
        font-family="'Cormorant Garamond', 'Cormorant Fallback', Georgia, serif"
        font-size="70" font-weight="300" letter-spacing="5"
        fill="currentColor">irai</text>

  {/* Amber dot — fixed brand accent */}
  <text x="240" y="74"
        font-family="'Cormorant Garamond', 'Cormorant Fallback', Georgia, serif"
        font-size="70" font-weight="300"
        fill="#D4820A">.</text>
</svg>

<style>
  .logo {
    display: inline-block;
    vertical-align: middle;
  }
</style>
