---
/*
 * /admin — overview-страница admin'ской панели.
 *
 * Дизайн принят 2026-06-13:
 *   1. Needs-attention — когорты без preподa с paid_count > 0.
 *   2. Key metrics (4) — students, cohorts (running/open), instructors,
 *      revenue month-to-date.
 *   3. Instructor workload table — running, open, pending HW,
 *      next session. Подсветка строки если running > OVERLOAD_THRESHOLD.
 *   4. Pipeline (7d) — applications new/awaiting/paid/running counts.
 *   5. Today's sessions — только ссылка на /admin/calendar.
 *
 * Все данные — real D1 queries (см. admin-overview.ts).
 */

import Layout from "../../layouts/admin/Layout.astro";
import InstructorHero from "../../components/instructor/InstructorHero.astro";
import StatCard from "../../components/dashboard/StatCard.astro";
import {
  countUnassignedCohorts,
  fetchOverviewMetrics,
  fetchPipelineFunnel,
  listInstructorWorkload,
  OVERLOAD_RUNNING_THRESHOLD,
} from "../../lib/server/admin-overview";
import { getUserWithRoles } from "../../lib/server/guards";
import { verifyRefreshSession } from "../../lib/server/session";

export const prerender = false;

// Inline guard (см. note в предыдущей версии — Astro adapter quirk
// при возврате Response из helper'a из non-[locale] route).
const env = Astro.locals.runtime.env;
const session = await verifyRefreshSession(env, Astro.request);
if (!session) {
  return Astro.redirect(`/en/login?return_to=${encodeURIComponent(Astro.url.pathname)}`, 302);
}
const user = await getUserWithRoles(env, session.userId);
if (!user) return Astro.redirect("/en/login", 302);
if (user.deactivated_at !== null) return Astro.redirect(`/${user.locale}/inactive`, 302);
if (!user.roles.has("admin")) return new Response(null, { status: 404 });

const locale = user.locale;
const ru = locale === "ru";

const [unassignedCohorts, metrics, pipeline, workload] = await Promise.all([
  countUnassignedCohorts(env),
  fetchOverviewMetrics(env),
  fetchPipelineFunnel(env),
  listInstructorWorkload(env),
]);

const intlLocale = ru ? "ru-RU" : "en-US";
const revenueFmt = new Intl.NumberFormat(intlLocale, {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0,
});
const sessionTimeFmt = new Intl.DateTimeFormat(intlLocale, {
  weekday: "short",
  day: "numeric",
  month: "short",
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "America/New_York",
});

const t = ru
  ? {
      eyebrow: "Админ",
      title: "Обзор.",
      subtitleFn: (n: number) => `${String(n)} студентов в обучении`,
      attentionTitle: "Требует внимания",
      attentionUnassigned: (n: number) =>
        `Когорты без преподавателя · ${String(n)}`,
      attentionAllClear: "Всё спокойно — open items нет.",
      metricStudents: "Студенты в обучении",
      metricStudentsSub: (n: number) => `+${String(n)} за неделю`,
      metricCohorts: "Идут сейчас",
      metricCohortsSub: (open: number) =>
        `${String(open)} открыты для записи`,
      metricInstructors: "Преподаватели",
      metricInstructorsSub: "активны",
      metricRevenue: "Выручка месяца",
      metricRevenueSub: "оплачено",
      workloadTitle: "Загрузка преподавателей",
      workloadEmpty: "Нет назначенных преподавателей.",
      colInstructor: "Преподаватель",
      colRunning: "Идут",
      colOpen: "Открыты",
      colPending: "На проверке",
      colNextSession: "Ближайшая сессия",
      pipelineTitle: "Pipeline · последние 7 дней",
      pipelineNewApps: "Новые заявки",
      pipelineAwaiting: "Ждут оплаты",
      pipelinePaid: "Оплачены",
      pipelineRunning: "В когорте",
      calendarTitle: "Сегодня",
      calendarCta: "Открыть календарь",
      seo: { title: "Админ — Moirai", description: "Админ-обзор." },
    }
  : {
      eyebrow: "Admin",
      title: "Overview.",
      subtitleFn: (n: number) => `${String(n)} students currently learning`,
      attentionTitle: "Needs attention",
      attentionUnassigned: (n: number) =>
        `Cohorts without instructor · ${String(n)}`,
      attentionAllClear: "All clear — no open items.",
      metricStudents: "Currently learning",
      metricStudentsSub: (n: number) => `+${String(n)} this week`,
      metricCohorts: "Currently teaching",
      metricCohortsSub: (open: number) =>
        `${String(open)} open for apply`,
      metricInstructors: "Instructors",
      metricInstructorsSub: "active",
      metricRevenue: "Revenue (month)",
      metricRevenueSub: "settled",
      workloadTitle: "Instructor workload",
      workloadEmpty: "No instructors assigned.",
      colInstructor: "Instructor",
      colRunning: "Running",
      colOpen: "Open",
      colPending: "Pending",
      colNextSession: "Next session",
      pipelineTitle: "Pipeline · last 7 days",
      pipelineNewApps: "New applications",
      pipelineAwaiting: "Awaiting payment",
      pipelinePaid: "Paid",
      pipelineRunning: "In cohort",
      calendarTitle: "Today",
      calendarCta: "Open calendar",
      seo: { title: "Admin — Moirai", description: "Admin overview." },
    };

const revenueDollars = metrics.revenue_month_cents / 100;
const revenueLabel = revenueFmt.format(revenueDollars);
const noAttention = unassignedCohorts === 0;
---

<Layout
  locale={locale}
  seo={{ title: t.seo.title, description: t.seo.description }}
  currentNavKey="overview"
  userRoles={user.roles}
>
  <InstructorHero
    eyebrow={t.eyebrow}
    title={t.title}
    subtitle={t.subtitleFn(metrics.active_students)}
  />

  <div class="admin-content">
    <section class="admin-attention" aria-label={t.attentionTitle}>
      <p class="admin-content__section-label">{t.attentionTitle}</p>
      {noAttention ? (
        <p class="admin-attention__clear">{t.attentionAllClear}</p>
      ) : (
        <ul class="admin-attention__list">
          {unassignedCohorts > 0 && (
            <li class="admin-attention__row">
              <a class="admin-attention__link" href="/admin/cohorts">
                {t.attentionUnassigned(unassignedCohorts)}
              </a>
            </li>
          )}
        </ul>
      )}
    </section>

    <section class="admin-content__stats" aria-label={t.eyebrow}>
      <StatCard
        label={t.metricStudents}
        value={[metrics.active_students, ""]}
        sub={t.metricStudentsSub(metrics.new_students_7d)}
      />
      <StatCard
        label={t.metricCohorts}
        value={[metrics.cohorts_running, ""]}
        sub={t.metricCohortsSub(metrics.cohorts_open)}
      />
      <StatCard
        label={t.metricInstructors}
        value={[metrics.active_instructors, ""]}
        sub={t.metricInstructorsSub}
      />
      <StatCard
        label={t.metricRevenue}
        value={revenueLabel}
        sub={t.metricRevenueSub}
        valueSmall
      />
    </section>

    <section class="admin-block" aria-label={t.workloadTitle}>
      <p class="admin-content__section-label">{t.workloadTitle}</p>
      {workload.length === 0 ? (
        <p class="admin-block__empty">{t.workloadEmpty}</p>
      ) : (
        <table class="admin-table">
          <thead>
            <tr>
              <th>{t.colInstructor}</th>
              <th class="admin-table__num">{t.colRunning}</th>
              <th class="admin-table__num">{t.colOpen}</th>
              <th class="admin-table__num">{t.colPending}</th>
              <th>{t.colNextSession}</th>
            </tr>
          </thead>
          <tbody>
            {workload.map((w) => {
              const overloaded = w.running_cohorts > OVERLOAD_RUNNING_THRESHOLD;
              const display = w.name?.trim() || w.email;
              const next = w.next_session_at
                ? sessionTimeFmt.format(new Date(w.next_session_at * 1000))
                : "—";
              return (
                <tr class:list={[overloaded ? "admin-table__row--alert" : null]}>
                  <td>{display}</td>
                  <td class="admin-table__num">{w.running_cohorts}</td>
                  <td class="admin-table__num">{w.open_cohorts}</td>
                  <td class="admin-table__num">{w.pending_homework}</td>
                  <td>{next}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </section>

    <section class="admin-content__two-col">
      <div class="admin-block">
        <p class="admin-content__section-label">{t.pipelineTitle}</p>
        <dl class="admin-pipeline">
          <div class="admin-pipeline__row">
            <dt>{t.pipelineNewApps}</dt>
            <dd>{pipeline.new_apps_7d}</dd>
          </div>
          <div class="admin-pipeline__row">
            <dt>{t.pipelineAwaiting}</dt>
            <dd>{pipeline.awaiting_payment}</dd>
          </div>
          <div class="admin-pipeline__row">
            <dt>{t.pipelinePaid}</dt>
            <dd>{pipeline.paid}</dd>
          </div>
          <div class="admin-pipeline__row">
            <dt>{t.pipelineRunning}</dt>
            <dd>{pipeline.running}</dd>
          </div>
        </dl>
      </div>

      <div class="admin-block">
        <p class="admin-content__section-label">{t.calendarTitle}</p>
        <a class="admin-calendar-link" href="/admin/calendar">{t.calendarCta} →</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .admin-content {
    padding: var(--space-xl) var(--container-pad) var(--space-3xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .admin-content__section-label {
    font-family: var(--font-body);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-md);
  }

  .admin-attention__clear {
    color: var(--text-faint);
    font-size: var(--type-body-sm);
    padding: var(--space-sm) 0;
  }
  .admin-attention__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .admin-attention__row {
    background: var(--amber-faint);
    border-left: 3px solid var(--amber);
    padding: var(--space-sm) var(--space-md);
    border-radius: 2px;
  }
  .admin-attention__link {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--type-body-sm);
    font-weight: 500;
  }
  .admin-attention__link:hover { color: var(--text-accent); }

  .admin-content__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .admin-content__two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .admin-block__empty {
    color: var(--text-faint);
    font-style: italic;
    padding: var(--space-md);
    border: 1px dashed var(--border);
    border-radius: 2px;
    text-align: center;
    font-size: var(--type-body-sm);
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: var(--type-body-sm);
  }
  .admin-table th {
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    border-bottom: 1px solid var(--border);
  }
  .admin-table td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }
  .admin-table th.admin-table__num,
  .admin-table td.admin-table__num { text-align: right; }
  .admin-table__row--alert { background: var(--amber-faint); }
  .admin-table__row--alert td { color: var(--text); }

  .admin-pipeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
  }
  .admin-pipeline__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-body);
  }
  .admin-pipeline__row:last-child { border-bottom: none; }
  .admin-pipeline__row dt {
    color: var(--text-muted);
    font-size: var(--type-body-sm);
  }
  .admin-pipeline__row dd {
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--type-body-lg);
    margin: 0;
  }

  .admin-calendar-link {
    color: var(--text-accent);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--type-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .admin-calendar-link:hover { color: var(--text); }

  @media (max-width: 768px) {
    .admin-content__stats { grid-template-columns: repeat(2, 1fr); }
    .admin-content__two-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .admin-content__stats { grid-template-columns: 1fr; }
  }
</style>
