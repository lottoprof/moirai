---
/*
 * /{locale}/journal — листинг постов журнала + empty-state.
 *
 * Источник: Content Collection journal (mdx files).
 * Empty-state: CTA "Apply now" → /apply (как у /works).
 *
 * Sort: date desc (свежие сверху). Tags под title как chips.
 *
 * Strategy: docs/works-and-journal-strategy.md §2 — главный SEO-driver
 * через long-tail keyword разборы.
 */

import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/public/Layout.astro";
import { formatDate } from "../../../lib/format-date";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { locale: "en" } },
    { params: { locale: "ru" } },
  ];
}

const { locale } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  throw new Error(`Unexpected locale: ${String(locale)}`);
}
const typedLocale: "en" | "ru" = locale;

type JournalEntry = CollectionEntry<"journal">;
const allPosts = await getCollection("journal");
const posts = allPosts
  .filter((p: JournalEntry) => p.id.endsWith(`.${typedLocale}`))
  .sort((a: JournalEntry, b: JournalEntry) => +b.data.date - +a.data.date);

const t = typedLocale === "ru"
  ? {
      eyebrow: "Журнал",
      title: "Разборы. Практика. Кино.",
      lede: "Длинные тексты о режиссуре, монтаже и сценарии — от людей, которые этим занимаются.",
      emptyTitle: "Первые материалы скоро.",
      emptyLede: "Готовим разборы по режиссуре, монтажу и сценарию. Пока — подайте заявку.",
      emptyCta: "Подать заявку",
      readMore: "Читать",
      seo: {
        title: "Журнал — Moirai",
        description: "Разборы по режиссуре, монтажу и сценарию от инструкторов Moirai. Длинные тексты для практикующих режиссёров и сценаристов.",
      },
    }
  : {
      eyebrow: "Journal",
      title: "Craft. Practice. Cinema.",
      lede: "Long-form essays on directing, editing, and screenwriting — by people who do it.",
      emptyTitle: "First essays coming soon.",
      emptyLede: "We're preparing breakdowns on directing, editing, and screenwriting. In the meantime — apply.",
      emptyCta: "Apply now",
      readMore: "Read",
      seo: {
        title: "Journal — Moirai",
        description: "Essays on directing, editing, and screenwriting by Moirai instructors. Long-form craft writing for working filmmakers.",
      },
    };

function postHref(p: JournalEntry): string {
  return `/${typedLocale}/journal/${p.data.slug}`;
}
---

<Layout locale={typedLocale} seo={{ title: t.seo.title, description: t.seo.description }}>
  <section class="journal-page" aria-labelledby="journal-title">
    <header class="journal-page__head">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1 id="journal-title" class="h1">{t.title}</h1>
      <p class="text-muted">{t.lede}</p>
    </header>

    {posts.length === 0 ? (
      <div class="journal-empty">
        <h2 class="journal-empty__title h3">{t.emptyTitle}</h2>
        <p class="journal-empty__lede text-muted">{t.emptyLede}</p>
        <a href={`/${typedLocale}/apply`} class="btn btn--primary btn--lg">{t.emptyCta}</a>
      </div>
    ) : (
      <ul class="journal-list" role="list">
        {posts.map((p: JournalEntry) => (
          <li class="journal-card">
            <a class="journal-card__link" href={postHref(p)}>
              <p class="journal-card__meta">
                <time datetime={p.data.date.toISOString()}>{formatDate(p.data.date, typedLocale)}</time>
                <span> · {p.data.author}</span>
              </p>
              <h2 class="journal-card__title h3">{p.data.title}</h2>
              <p class="journal-card__excerpt text-muted">{p.data.excerpt}</p>
              {p.data.tags.length > 0 && (
                <ul class="journal-card__tags" role="list">
                  {p.data.tags.map((tag: string) => (
                    <li class="journal-card__tag">#{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>

<style>
  .journal-page {
    padding: var(--space-3xl) var(--container-pad);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .journal-page__head {
    max-width: 720px;
    margin: 0 auto var(--space-3xl);
    text-align: center;
  }
  .journal-page__head .eyebrow {
    margin-bottom: var(--space-md);
  }
  .journal-page__head .h1 {
    margin-bottom: var(--space-md);
  }

  /* Empty-state — CTA в центре, направляем на /apply (как у /works). */
  .journal-empty {
    text-align: center;
    padding: var(--space-3xl) 0;
    max-width: 480px;
    margin: 0 auto;
  }
  .journal-empty__title {
    margin-bottom: var(--space-md);
  }
  .journal-empty__lede {
    margin-bottom: var(--space-2xl);
  }

  /* List — вертикальный список карточек, max-width для читаемости. */
  .journal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .journal-card {
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--border);
  }
  .journal-card:last-child {
    border-bottom: none;
  }
  .journal-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .journal-card__link:hover {
    opacity: 0.85;
  }
  .journal-card__link:active {
    opacity: 0.7;
  }

  .journal-card__meta {
    margin: 0 0 var(--space-sm);
    font-size: var(--type-micro-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .journal-card__title {
    margin: 0 0 var(--space-md);
  }
  .journal-card__excerpt {
    margin: 0 0 var(--space-md);
    line-height: 1.6;
  }

  .journal-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .journal-card__tag {
    font-size: var(--type-body-sm);
    color: var(--text-faint);
  }
</style>
