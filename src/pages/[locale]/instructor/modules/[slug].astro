---
/*
 * /{locale}/instructor/modules/{slug} — read-only preview модуля для preподa.
 *
 * Render: body + workbook через MarkdownContent (тот же путь что student),
 * presentation — ссылка на /api/modules/preview endpoint.
 *
 * Methodist загружает, instructor видит без unlock-check.
 */

import Layout from "../../../../layouts/instructor/Layout.astro";
import MarkdownContent from "../../../../components/shared/MarkdownContent.astro";
import { requireRole } from "../../../../lib/server/guards";

export const prerender = false;

const { locale, slug } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  return Astro.redirect("/en/instructor");
}
const typedLocale: "en" | "ru" = locale;
const ru = typedLocale === "ru";
if (!slug || typeof slug !== "string") return new Response(null, { status: 404 });

const userOrRes = await requireRole(Astro, "instructor");
if (userOrRes instanceof Response) return userOrRes;
const user = userOrRes;
const env = Astro.locals.runtime.env;

interface ModuleRow {
  title: string;
  body_r2_key: string | null;
  presentation_r2_key: string | null;
  workbook_r2_key: string | null;
}

const row = await env.DB.prepare(
  `SELECT title, body_r2_key, presentation_r2_key, workbook_r2_key
     FROM modules WHERE slug = ? AND locale = ?`,
).bind(slug, typedLocale).first<ModuleRow>();

if (!row) return new Response(null, { status: 404 });

async function fetchR2Text(key: string | null): Promise<string | null> {
  if (!key) return null;
  try {
    const obj = await env.MODULE_CONTENT.get(key);
    if (!obj) return null;
    return await obj.text();
  } catch (err) {
    console.error("[instructor module preview] R2 fetch failed", err);
    return null;
  }
}

const bodyMd = await fetchR2Text(row.body_r2_key);
const workbookMd = await fetchR2Text(row.workbook_r2_key);

const t = ru
  ? {
      backLink: "← К модулям",
      bodyTitle: "Body", workbookTitle: "Workbook",
      bodyMissing: "Body не загружен.", workbookMissing: "Workbook не загружен.",
      presentationBtn: "Открыть презентацию",
      seo: { title: `${row.title} — Преподаватель`, description: "Module preview" },
    }
  : {
      backLink: "← Back to modules",
      bodyTitle: "Body", workbookTitle: "Workbook",
      bodyMissing: "Body not uploaded.", workbookMissing: "Workbook not uploaded.",
      presentationBtn: "Open presentation",
      seo: { title: `${row.title} — Instructor`, description: "Module preview" },
    };
---

<Layout
  locale={typedLocale}
  seo={t.seo}
  currentNavKey="modules"
  userRoles={user.roles}
>
  <div class="instr-mod">
    <a class="instr-mod__back" href={`/${typedLocale}/instructor/modules`}>{t.backLink}</a>

    <header class="instr-mod__head">
      <h1 class="instr-mod__title">{row.title}</h1>
      <p class="instr-mod__slug">{slug}</p>
    </header>

    {row.presentation_r2_key && (
      <p class="instr-mod__cta">
        <a class="instr-mod__btn" href={`/api/modules/preview/${encodeURIComponent(slug)}/${typedLocale}/presentation`} target="_blank" rel="noopener">
          {t.presentationBtn}
        </a>
      </p>
    )}

    <section class="instr-mod__section">
      <h2 class="instr-mod__section-title">{t.bodyTitle}</h2>
      {bodyMd ? <MarkdownContent md={bodyMd} /> : <p class="instr-mod__missing">{t.bodyMissing}</p>}
    </section>

    <section class="instr-mod__section">
      <h2 class="instr-mod__section-title">{t.workbookTitle}</h2>
      {workbookMd ? <MarkdownContent md={workbookMd} /> : <p class="instr-mod__missing">{t.workbookMissing}</p>}
    </section>
  </div>
</Layout>

<style>
  .instr-mod {
    padding: var(--space-xl) var(--container-pad) var(--space-3xl);
    max-width: 800px;
    margin: 0 auto;
  }
  .instr-mod__back {
    display: inline-block;
    color: var(--text-faint);
    text-decoration: none;
    font-size: var(--type-micro-md);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }
  .instr-mod__back:hover { color: var(--text); }
  .instr-mod__head { margin-bottom: var(--space-lg); }
  .instr-mod__title {
    font-family: var(--font-display);
    font-size: var(--type-display-md);
    font-weight: 400;
    color: var(--text);
    margin: 0;
  }
  .instr-mod__slug { color: var(--text-faint); font-family: var(--font-body); font-size: var(--type-micro-md); margin: 4px 0 0; }
  .instr-mod__cta { margin: 0 0 var(--space-xl); }
  .instr-mod__btn {
    padding: 10px 18px;
    background: var(--amber);
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    border-radius: 2px;
    display: inline-block;
  }
  .instr-mod__btn:hover { background: var(--amber-light); }
  .instr-mod__section { margin-bottom: var(--space-xl); padding-bottom: var(--space-xl); border-bottom: 1px solid var(--border); }
  .instr-mod__section-title {
    font-family: var(--font-display);
    font-size: var(--type-display-sm);
    font-weight: 400;
    margin: 0 0 var(--space-md);
    color: var(--text);
  }
  .instr-mod__missing { color: var(--text-faint); font-style: italic; }
</style>
