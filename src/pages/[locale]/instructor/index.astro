---
/*
 * /{locale}/instructor — overview-страница инструктора.
 *
 * Instructor LK v2 Q2-expansion (rewritten 2026-06-08):
 *   Grid из cohort cards — main entity для preпода. Top stats row убран
 *   (метрики per-cohort вместо). Pending queue + students — теперь в
 *   cohort cards (counts) и /instructor/cohorts/[id] (детали).
 *
 * Layout: InstructorLayout. Guard: requireRole(ctx, 'instructor').
 */

import Layout from "../../../layouts/instructor/Layout.astro";
import InstructorHero from "../../../components/instructor/InstructorHero.astro";
import CohortCard from "../../../components/instructor/CohortCard.astro";
import { requireRole } from "../../../lib/server/guards";
import { listInstructorCohorts } from "../../../lib/server/instructor-homework";
import { getEntry } from "astro:content";

export const prerender = false;

const { locale } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  return Astro.redirect("/en/instructor");
}
const typedLocale: "en" | "ru" = locale;
const ru = typedLocale === "ru";

const userOrRes = await requireRole(Astro, "instructor");
if (userOrRes instanceof Response) return userOrRes;
const user = userOrRes;
const env = Astro.locals.runtime.env;

const cards = await listInstructorCohorts(env, user.id);

// Resolve programme titles + next session module titles
const programmeSlugs = Array.from(new Set(cards.map((c) => c.programme_slug)));
const programmeTitleMap = new Map<string, string>();
await Promise.all(programmeSlugs.map(async (slug) => {
  const entry = await getEntry("programmes", `${slug}.${typedLocale}`);
  if (entry) programmeTitleMap.set(slug, entry.data.title);
}));

const moduleSlugs = Array.from(new Set(
  cards.map((c) => c.next_session_module_slug).filter((s): s is string => Boolean(s)),
));
const moduleTitleMap = new Map<string, string>();
if (moduleSlugs.length > 0) {
  const placeholders = moduleSlugs.map(() => "?").join(",");
  const rows = await env.DB.prepare(
    `SELECT slug, title FROM modules WHERE slug IN (${placeholders}) AND locale = ?`,
  ).bind(...moduleSlugs, typedLocale).all<{ slug: string; title: string }>();
  for (const r of rows.results) moduleTitleMap.set(r.slug, r.title);
}

// Total pending across all cohorts — для subtitle
const totalPending = cards.reduce((sum, c) => sum + c.pending_submissions, 0);

const t = ru
  ? {
      eyebrow: "Преподаватель",
      title: "Мои когорты",
      subtitle: totalPending === 0
        ? "Очередь чиста"
        : `${totalPending.toString()} работ${totalPending === 1 ? "а" : totalPending < 5 ? "ы" : ""} на проверке`,
      empty: "Когорты ещё не назначены.",
      seo: { title: "Преподаватель — Moirai", description: "Мои когорты и проверка ДЗ." },
    }
  : {
      eyebrow: "Instructor",
      title: "My cohorts",
      subtitle: totalPending === 0
        ? "Queue clear"
        : `${totalPending.toString()} submission${totalPending === 1 ? "" : "s"} awaiting review`,
      empty: "No cohorts assigned yet.",
      seo: { title: "Instructor — Moirai", description: "My cohorts and homework review." },
    };
---

<Layout
  locale={typedLocale}
  seo={{ title: t.seo.title, description: t.seo.description }}
  currentNavKey="cohorts"
  userRoles={user.roles}
>
  <InstructorHero eyebrow={t.eyebrow} title={t.title} subtitle={t.subtitle} />

  <div class="instructor-content">
    {cards.length === 0 ? (
      <p class="instructor-content__empty">{t.empty}</p>
    ) : (
      <div class="cohort-grid">
        {cards.map((c) => (
          <CohortCard
            locale={typedLocale}
            cohortId={c.cohort_id}
            programmeTitle={programmeTitleMap.get(c.programme_slug) ?? c.programme_slug}
            startDate={c.start_date}
            status={c.status as "open" | "running" | "completed" | "cancelled"}
            activeStudents={c.active_students}
            pendingSubmissions={c.pending_submissions}
            reviewedThisWeek={c.reviewed_this_week}
            lateSubmissions={c.late_submissions}
            nextSessionAt={c.next_session_at}
            nextSessionModuleTitle={c.next_session_module_slug ? (moduleTitleMap.get(c.next_session_module_slug) ?? c.next_session_module_slug) : null}
            meetingProvider={c.meeting_provider}
            meetingJoinUrl={c.meeting_host_url ?? c.meeting_url}
          />
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .instructor-content {
    padding: var(--space-xl) var(--container-pad) var(--space-3xl);
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .instructor-content__empty {
    color: var(--text-faint);
    font-style: italic;
    padding: var(--space-2xl);
    border: 1px dashed var(--border);
    border-radius: 2px;
    text-align: center;
  }
  .cohort-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-md);
  }
</style>
