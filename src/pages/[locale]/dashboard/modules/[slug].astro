---
/*
 * /{locale}/dashboard/modules/{slug} — страница студента с workbook модуля.
 *
 * Stage B (Student LK v2). SSR + requireRole('student').
 *
 * Logic:
 *   1. Resolve module через getModuleForStudent (ownership + schedule-based unlock)
 *   2. Fetch workbook из R2 (env.MODULE_CONTENT.get(workbook_r2_key))
 *   3. Render markdown via marked (описание ДЗ — секция в workbook'е)
 *   4. markModuleViewed (audit only, view_status='viewed')
 *
 * Если модуль locked или не принадлежит студенту → 404 (info-hiding).
 * Если workbook не найден в R2 → fallback "Materials coming soon".
 *
 * Stage E добавит tabs (Presentation / Workbook / Homework) — пока
 * показываем только workbook на single page.
 */

import DashboardLayout from "../../../../layouts/dashboard/Layout.astro";
import MarkdownContent from "../../../../components/shared/MarkdownContent.astro";
import SubmissionCard from "../../../../components/dashboard/SubmissionCard.astro";
import SubmissionUploader from "../../../../components/dashboard/SubmissionUploader.astro";
import ModulesDrawer from "../../../../components/dashboard/ModulesDrawer.astro";
import { requireRole } from "../../../../lib/server/guards";
import {
  getModuleForStudent,
  markModuleViewed,
  listEnrollmentModules,
} from "../../../../lib/server/student-modules";
import {
  listSubmissionsForModule,
  HOMEWORK_ALLOWED_MIME,
} from "../../../../lib/server/homework";
import { LK_CONFIG } from "../../../../lib/config/lk";
import { getEntry } from "astro:content";

export const prerender = false;

const { locale, slug } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  return Astro.redirect("/en/dashboard");
}
const typedLocale: "en" | "ru" = locale;
const ru = typedLocale === "ru";
if (!slug || typeof slug !== "string") return new Response(null, { status: 404 });

const userOrRes = await requireRole(Astro, "student");
if (userOrRes instanceof Response) return userOrRes;
const user = userOrRes;
const env = Astro.locals.runtime.env;

const module_ = await getModuleForStudent(env, user.id, slug, typedLocale);
if (!module_) return new Response(null, { status: 404 });
if (!module_.unlocked) {
  return Astro.redirect(`/${typedLocale}/dashboard`);
}

// Audit view (idempotent, не блокирует render)
await markModuleViewed(env, module_.enrollment_id, module_.slug, typedLocale);

// Fetch workbook from R2 (Stage B: workbook_r2_key replaces body_r2_key)
let bodyMarkdown: string | null = null;
let bodyError: string | null = null;
if (!module_.workbook_r2_key) {
  bodyError = "missing";
} else {
  try {
    const obj = await env.MODULE_CONTENT.get(module_.workbook_r2_key);
    if (obj) {
      bodyMarkdown = await obj.text();
    } else {
      bodyError = "missing";
    }
  } catch (err) {
    console.error("[module page] R2 fetch failed:", err);
    bodyError = "fetch_error";
  }
}

// Markdown render — через <MarkdownContent slug=...> в шаблоне.
// Component обеспечивает image rewrite, YT auto-embed + modal lightbox
// единообразно с admin/instructor view.

// Parse JSON arrays
let objectives: string[] = [];
let concepts: string[] = [];
try {
  const parsed = JSON.parse(module_.objectives_json);
  if (Array.isArray(parsed)) objectives = parsed.filter((x): x is string => typeof x === "string");
} catch { /* ignore */ }
try {
  const parsed = JSON.parse(module_.concepts_json);
  if (Array.isArray(parsed)) concepts = parsed.filter((x): x is string => typeof x === "string");
} catch { /* ignore */ }

// Stage C: homework submissions для этого module
const submissions = module_.has_homework
  ? await listSubmissionsForModule(env, module_.enrollment_id, module_.slug, typedLocale)
  : [];
const allowedMimes = Array.from(HOMEWORK_ALLOWED_MIME);

// Stage E: drawer data
const drawerModules = await listEnrollmentModules(env, module_.enrollment_id, typedLocale);
const drawerDone = drawerModules.filter((m) => m.status === "done").length;

// Find programme_slug → title для drawer header
const programmeRow = await env.DB.prepare(
  `SELECT programme_slug FROM enrollments WHERE id = ? LIMIT 1`,
)
  .bind(module_.enrollment_id)
  .first<{ programme_slug: string }>();
const programmeEntry = programmeRow
  ? await getEntry("programmes", `${programmeRow.programme_slug}.${typedLocale}`)
  : null;
const programmeTitle = programmeEntry?.data.title ?? "Programme";

const t = ru
  ? {
      backLink: "← Назад к модулям",
      moduleNum: (n: number) => `Модуль ${String(n).padStart(2, "0")}`,
      objectivesTitle: "Цели",
      conceptsTitle: "Понятия",
      bodyMissing: "Материал ещё не загружен. Методист готовит контент.",
      bodyError: "Не удалось загрузить материал. Попробуйте обновить страницу.",
      homeworkTitle: "Домашнее задание",
      homeworkNoSubmissions: "Вы ещё не сдали ДЗ для этого модуля.",
      homeworkAttemptsLabel: (n: number) => `Ваши попытки (${n.toString()})`,
      homeworkUploadLabel: "Загрузить новую версию",
      seo: {
        title: `${module_.title} — Moirai`,
        description: module_.summary ?? `Модуль программы Moirai: ${module_.title}.`,
      },
    }
  : {
      backLink: "← Back to modules",
      moduleNum: (n: number) => `Module ${String(n).padStart(2, "0")}`,
      objectivesTitle: "Objectives",
      conceptsTitle: "Concepts",
      bodyMissing: "Material not yet uploaded. The methodist is preparing content.",
      bodyError: "Failed to load material. Try reloading the page.",
      homeworkTitle: "Homework",
      homeworkNoSubmissions: "You haven't submitted homework for this module yet.",
      homeworkAttemptsLabel: (n: number) => `Your attempts (${n.toString()})`,
      homeworkUploadLabel: "Upload a new version",
      seo: {
        title: `${module_.title} — Moirai`,
        description: module_.summary ?? `Moirai programme module: ${module_.title}.`,
      },
    };

// Cache-Control: paid content, per-user — privately
Astro.response.headers.set("Cache-Control", "private, no-store");
---

<DashboardLayout
  locale={typedLocale}
  seo={{ title: t.seo.title, description: t.seo.description }}
  currentNavKey="dashboard"
  userRoles={user.roles}
  showDrawerTrigger={true}
>
  <ModulesDrawer
    slot="drawer"
    locale={typedLocale}
    programmeTitle={programmeTitle}
    modules={drawerModules.map((m) => ({
      slug: m.slug,
      title: m.title,
      orderIdx: m.order_idx,
      status: m.status === "done" ? "done" as const : !m.unlocked ? "locked" as const : "active" as const,
    }))}
    doneCount={drawerDone}
    totalCount={drawerModules.length}
    currentSlug={module_.slug}
  />
  <article class="module-page">
    <a href={`/${typedLocale}/dashboard`} class="module-page__back">{t.backLink}</a>

    <header class="module-page__head">
      <p class="module-page__eyebrow">
        {t.moduleNum(module_.order_idx + 1)}
        {module_.track && <span class="module-page__track"> · {module_.track.toUpperCase()}</span>}
      </p>
      <h1 class="module-page__title">{module_.title}</h1>
      {module_.summary && <p class="module-page__summary">{module_.summary}</p>}
      <a class="module-page__present-cta"
         href={`/${typedLocale}/dashboard/modules/${module_.slug}/present`}
         target="_blank" rel="noopener">
        {ru ? "Открыть в режиме презентации" : "Open in presentation mode"}
      </a>
    </header>

    {(objectives.length > 0 || concepts.length > 0) && (
      <section class="module-page__meta">
        {objectives.length > 0 && (
          <div>
            <h2 class="module-page__meta-title">{t.objectivesTitle}</h2>
            <ul class="module-page__meta-list">
              {objectives.map((o) => <li>{o}</li>)}
            </ul>
          </div>
        )}
        {concepts.length > 0 && (
          <div>
            <h2 class="module-page__meta-title">{t.conceptsTitle}</h2>
            <p class="module-page__concepts">{concepts.join(" · ")}</p>
          </div>
        )}
      </section>
    )}

    <div class="module-page__body">
      {bodyMarkdown ? (
        <MarkdownContent md={bodyMarkdown} slug={slug} />
      ) : bodyError === "missing" ? (
        <p class="module-page__placeholder">{t.bodyMissing}</p>
      ) : (
        <p class="module-page__placeholder">{t.bodyError}</p>
      )}
    </div>

    {Boolean(module_.has_homework) && (
      <section class="module-page__homework" aria-labelledby="hw-label">
        <h2 id="hw-label" class="module-page__hw-title">{t.homeworkTitle}</h2>

        <SubmissionUploader
          moduleSlug={module_.slug}
          locale={typedLocale}
          capBytes={LK_CONFIG.homework_upload_cap_bytes}
          allowedMimes={allowedMimes}
        />

        {submissions.length > 0 ? (
          <div class="module-page__submissions">
            <p class="module-page__hw-sublabel">{t.homeworkAttemptsLabel(submissions.length)}</p>
            {submissions.map((s) => (
              <SubmissionCard submission={s} locale={typedLocale} />
            ))}
          </div>
        ) : (
          <p class="module-page__hw-empty">{t.homeworkNoSubmissions}</p>
        )}
      </section>
    )}

  </article>
</DashboardLayout>

<style>
  .module-page {
    padding: var(--space-2xl) var(--container-pad) var(--space-3xl);
    max-width: 800px;
    margin: 0 auto;
  }
  .module-page__back {
    display: inline-block;
    margin-bottom: var(--space-xl);
    font-size: var(--type-micro-md);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .module-page__back:hover {
    color: var(--amber);
    border-bottom-color: var(--amber);
  }

  .module-page__head {
    margin-bottom: var(--space-2xl);
  }
  .module-page__eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-accent);
    margin: 0 0 var(--space-sm);
  }
  .module-page__track {
    color: var(--text-faint);
  }
  .module-page__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-md);
    color: var(--text);
  }
  .module-page__summary {
    font-size: var(--type-body-lg);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .module-page__meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-elevated);
    margin-bottom: var(--space-2xl);
  }
  .module-page__meta-title {
    font-family: var(--font-body);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 var(--space-sm);
  }
  .module-page__meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .module-page__meta-list li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-2xs);
  }
  .module-page__meta-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--amber);
  }
  .module-page__concepts {
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .module-page__body {
    color: var(--text-muted);
    font-size: var(--type-body-md);
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
  }
  .module-page__body :global(h2) {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }
  .module-page__body :global(h3) {
    font-family: var(--font-body);
    font-size: var(--type-body-md);
    font-weight: 500;
    color: var(--text);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    letter-spacing: var(--tracking-wide);
  }
  .module-page__body :global(p) { margin-bottom: var(--space-md); }
  .module-page__body :global(ul),
  .module-page__body :global(ol) {
    margin: var(--space-md) 0;
    padding-left: 1.5em;
  }
  .module-page__body :global(li) { margin-bottom: var(--space-xs); }
  .module-page__body :global(a) {
    color: var(--amber);
    border-bottom: 1px solid var(--amber-faint);
  }
  .module-page__body :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-lg) 0;
    background: var(--bg-elevated);
    color: var(--text);
  }
  .module-page__body :global(code) {
    font-family: var(--font-mono, ui-monospace, monospace);
    background: var(--bg-elevated);
    padding: 1px 6px;
    border-radius: 2px;
    color: var(--text);
  }
  .module-page__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: var(--type-body-sm);
  }
  .module-page__body :global(th),
  .module-page__body :global(td) {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
  }
  .module-page__body :global(th) {
    background: var(--bg-elevated);
    color: var(--text);
    font-weight: 500;
  }
  .module-page__placeholder {
    color: var(--text-faint);
    font-style: italic;
    padding: var(--space-lg);
    border: 1px dashed var(--border);
    border-radius: 2px;
    text-align: center;
  }
  .module-page__present-cta {
    display: inline-block;
    margin-top: var(--space-md);
    padding: 8px 16px;
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--amber) 40%, transparent);
    text-decoration: none;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .module-page__present-cta:hover {
    background: var(--amber-faint);
    border-color: var(--amber);
  }

  /* Stage C homework section */
  .module-page__homework {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .module-page__hw-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 400;
    color: var(--text);
    margin: 0;
  }
  .module-page__hw-sublabel {
    font-family: var(--font-body);
    font-size: var(--type-micro-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0;
  }
  .module-page__submissions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .module-page__hw-empty {
    color: var(--text-faint);
    font-size: var(--type-body-sm);
    font-style: italic;
    margin: 0;
  }
</style>
