---
/*
 * Главная страница (`/{locale}/`).
 *
 * Контент берётся из Content Collection `pages`, entry id = `home.<locale>`.
 * Секции — free-form в zod schema (`pages` коллекция); этот шаблон
 * локально декларирует HomeSections тип для type-safe рендера.
 *
 * Stage 4f integration: stub-разметка заменена композицией компонентов
 * из `src/components/public/` (Stage 4a-4e). Визуально страница
 * соответствует `docs/moirai-home.html`. Шрифты — fallback chain
 * (Stage 5 добавит self-hosted woff2). Schema.org JSON-LD — Stage 6.
 *
 * `prerender = true` — статика по умолчанию для SEO-страниц
 * (см. ADR `dd7d91c` Sprint 0 bootstrap).
 */

import { getEntry, getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/public/Layout.astro";
import OrganizationSchema from "../../components/schema/OrganizationSchema.astro";
import FaqSchema from "../../components/schema/FaqSchema.astro";
import CourseSchema from "../../components/schema/CourseSchema.astro";
import PersonSchema from "../../components/schema/PersonSchema.astro";
import Hero from "../../components/public/Hero.astro";
import PromoStrip, { type PromoPlate } from "../../components/public/PromoStrip.astro";
import PhotoStrip, { type PhotoItem } from "../../components/public/PhotoStrip.astro";
import type { ImageMetadata } from "astro";
import InstructorCard from "../../components/public/InstructorCard.astro";
import StatsBanner from "../../components/public/StatsBanner.astro";
import WhoCard from "../../components/public/WhoCard.astro";
import ProgrammeCard from "../../components/public/ProgrammeCard.astro";
import TierCard from "../../components/public/TierCard.astro";
import FeatureItem from "../../components/public/FeatureItem.astro";
import OutcomeItem from "../../components/public/OutcomeItem.astro";
import AiModule from "../../components/public/AiModule.astro";
import Faq from "../../components/public/Faq.astro";
import FinalCta from "../../components/public/FinalCta.astro";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { locale: "en" } },
    { params: { locale: "ru" } },
  ];
}

type Locale = "en" | "ru";

const { locale } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  throw new Error(`Unexpected locale: ${String(locale)}`);
}
const typedLocale: Locale = locale;

const home = await getEntry("pages", `home.${typedLocale}`);
if (!home) {
  throw new Error(`home.${typedLocale} not found in pages collection`);
}

// Local section types — narrow loose `Record<string, unknown>` schema
// под shape, который пишут home.{en,ru}.mdx. Schema в config.ts
// намеренно free-form: разные страницы в pages коллекции (home, faq,
// about, legal-*) имеют разные shape sections.
interface CtaItem {
  title: string;
  body: string;
}
interface Track {
  name: string;
  tagline: string;
  body: string;
  topics: string[];
}
interface CurriculumLevel {
  id: string;
  title: string;
  lede: string;
  tracks: Track[];
  final: { title: string; body: string };
}
interface StatItem {
  value: string;
  label: string;
  accent?: boolean;
}
interface PhotoStripSection {
  label: string;
  tone: "warm" | "cool";
  cols: 3 | 4;
  photos: { src: string; alt: string }[];
}
interface HomeSections {
  hero: {
    eyebrow: string; title: string; lede: string; cta_text: string; cta_href: string;
    cohort_urgency?: string; bg_image?: string;
  };
  photo_strips?: {
    behind_camera: PhotoStripSection;
    from_our_films: PhotoStripSection;
  };
  stats: { items: StatItem[] };
  who: { eyebrow: string; title: string; audiences: CtaItem[] };
  curriculum: { eyebrow: string; title: string; intro: string; levels: CurriculumLevel[] };
  included: { eyebrow: string; title: string; items: CtaItem[] };
  instructors: { eyebrow: string; title: string; ids: string[] };
  after: { eyebrow: string; title: string; intro: string; items: CtaItem[] };
  pricing: { eyebrow: string; title: string; note: string };
  ai_module: { badge: string; title: string; body: string; cta_text: string; cta_href: string };
  final_cta: { eyebrow: string; title: string; body: string; urgency: string; cta_text: string; cta_href: string };
}

const sections = home.data.sections as HomeSections | undefined;
if (!sections) {
  throw new Error(`home.${typedLocale}: sections missing in frontmatter`);
}

const seo = home.data.seo;
const faqs: { q: string; a: string }[] = home.data.faqs ?? [];

// ============================================================
// Hero promo plates (Stage_advertising):
// читаем active announcements (lifecycle starts_at/ends_at), сортируем
// по priority desc + starts_at asc — те же правила что были у бывшего
// top-of-page <AnnouncementBar />. Каждая entry рендерится плашкой
// под APPLY кнопкой и даёт slug-targeted internal link для SEO.
// См. ROADMAP — Sprint 2 ssg-sync из D1 заменит manual edits в коллекции.
// ============================================================
type AnnouncementEntry = CollectionEntry<"announcements">;
const nowMs = Date.now();
const allAnnouncements = await getCollection("announcements");
const heroPlates: PromoPlate[] = allAnnouncements
  .filter((e: AnnouncementEntry) => e.id.endsWith(`.${typedLocale}`))
  .filter((e: AnnouncementEntry) =>
    e.data.starts_at.getTime() <= nowMs && nowMs <= e.data.ends_at.getTime(),
  )
  .sort((a: AnnouncementEntry, b: AnnouncementEntry) => {
    if (b.data.priority !== a.data.priority) return b.data.priority - a.data.priority;
    return a.data.starts_at.getTime() - b.data.starts_at.getTime();
  })
  .filter((e: AnnouncementEntry): e is AnnouncementEntry & { data: { cta_text: string; cta_href: string } } =>
    typeof e.data.cta_text === "string" && typeof e.data.cta_href === "string",
  )
  .map((e: AnnouncementEntry) => ({
    kind: e.data.kind,
    text: e.data.text,
    cta_text: e.data.cta_text as string,
    cta_href: e.data.cta_href as string,
    slug: e.id.replace(/\.(en|ru)$/, ""),
  }));

// ============================================================
// Photo assets (Stage_visual):
// Bulk-import всех jpg из src/assets/home/, mapping name → ImageMetadata.
// Источник: пример клиента Film_Site_6.html — 11 фото (1 hero bg + 4
// "Behind the Camera" + 6 "From Our Films"). Sprint 2 — миграция в R2.
// ============================================================
const homeImages = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/home/*.jpg",
  { eager: true },
);

function resolveImg(name: string): ImageMetadata {
  const key = `../../assets/home/${name}.jpg`;
  const mod = homeImages[key];
  if (!mod) throw new Error(`home image not found: ${name} (expected ${key})`);
  return mod.default;
}

const heroBgImage = sections.hero.bg_image ? resolveImg(sections.hero.bg_image) : undefined;

function buildStripPhotos(section: PhotoStripSection | undefined): PhotoItem[] {
  if (!section) return [];
  return section.photos.map((p) => ({
    src: resolveImg(p.src),
    alt: p.alt,
  }));
}

const behindCameraSection = sections.photo_strips?.behind_camera;
const fromOurFilmsSection = sections.photo_strips?.from_our_films;
const behindCameraPhotos = buildStripPhotos(behindCameraSection);
const fromOurFilmsPhotos = buildStripPhotos(fromOurFilmsSection);

// Programme cards: фиксированный порядок (Beginner → Intermediate → Bundle → Individual).
// Читаем programmes коллекцию + фильтруем по локали, потом по slug.
type ProgrammeEntry = CollectionEntry<"programmes">;
const allProgrammes = await getCollection("programmes");
const cardOrder = ["beginner", "intermediate", "bundle", "individual"];
const localeProgrammes = allProgrammes.filter((p: ProgrammeEntry) => p.id.endsWith(`.${typedLocale}`));
const programmeCards = cardOrder
  .map((slug) => localeProgrammes.find((p: ProgrammeEntry) => p.id === `${slug}.${typedLocale}`))
  .filter((p): p is ProgrammeEntry => p !== undefined)
  // FLOW-29: программа с `published: false` показывается только по прямой
  // ссылке (/programmes/<id>), не появляется в home grid / cards / pricing.
  .filter((p: ProgrammeEntry) => p.data.published !== false);

// Currency formatter: cents + currency code → "<symbol><whole units>".
function formatPrice(cents: number, currency: string, locale: "en" | "ru"): string {
  if (cents === 0) return locale === "ru" ? "по запросу" : "on request";
  const value = Math.round(cents / 100);
  const symbol = currency === "EUR" ? "€" : currency === "USD" ? "$" : currency;
  return `${symbol}${value}`;
}

/**
 * Programme features (open key-value record в zod) → читаемый список
 * для TierCard. Известные ключи переводятся локально-зависимо,
 * незнакомые ключи игнорируются (forward-compat для будущих фич).
 *
 * Stage 9: пока live на main только; ту же логику позже можно
 * подтянуть в programme detail page.
 */
type FeatureValue = boolean | number | string;
function programmeFeaturesToList(
  features: Record<string, FeatureValue>,
  locale: "en" | "ru",
): string[] {
  const out: string[] = [];
  const ru = locale === "ru";

  const cohortBased = features.cohort_based === true;
  const cohortMax = typeof features.cohort_max === "number" ? features.cohort_max : null;
  if (cohortBased && cohortMax !== null) {
    out.push(ru
      ? `Когортное обучение · до ${cohortMax.toString()} человек`
      : `Cohort-based · up to ${cohortMax.toString()} students`);
  } else if (features.cohort_based === false) {
    out.push(ru ? "Без когорты · 1:1 с инструктором" : "No cohort · 1:1 with instructor");
  }

  if (typeof features.sessions_per_week === "number" && features.sessions_per_week > 0) {
    const n = features.sessions_per_week;
    out.push(ru ? `${n.toString()} занятия в неделю` : `${n.toString()} sessions/week`);
  }

  if (typeof features.one_on_one_sessions === "number" && features.one_on_one_sessions > 0) {
    const n = features.one_on_one_sessions;
    out.push(ru
      ? `${n.toString()} личных сессий с инструктором`
      : `${n.toString()} × 1:1 sessions with instructor`);
  }

  if (typeof features.consultations_count === "number" && features.consultations_count > 0) {
    const n = features.consultations_count;
    out.push(ru
      ? `${n.toString()} вводная консультация · подбор плана`
      : `${n.toString()} discovery call · personal plan`);
  }

  if (features.custom_pacing === true) {
    out.push(ru ? "Гибкий график" : "Flexible schedule");
  }

  if (features.homework_review === true) {
    out.push(ru ? "Личный разбор каждой работы" : "Personal review of every assignment");
  }

  if (features.recordings_access === true) {
    out.push(ru ? "Пожизненный доступ к записям" : "Lifetime access to recordings");
  }

  return out;
}

function programmeMeta(p: ProgrammeEntry, locale: "en" | "ru"): string {
  const d = p.data;
  if (d.modules.length === 0) {
    return locale === "ru" ? "Гибкий план · 1:1 с инструктором" : "Flexible plan · 1:1 with instructor";
  }
  const modulesLabel = locale === "ru"
    ? `${d.module_count_hint} модул${d.module_count_hint % 10 === 1 && d.module_count_hint !== 11 ? "ь" : "ей"}`
    : `${d.module_count_hint} module${d.module_count_hint === 1 ? "" : "s"}`;
  const lessonsLabel = locale === "ru"
    ? `${d.lessons_total_hint} занят${d.lessons_total_hint % 10 === 1 && d.lessons_total_hint !== 11 ? "ие" : "ий"}`
    : `${d.lessons_total_hint} lesson${d.lessons_total_hint === 1 ? "" : "s"}`;
  return `${modulesLabel} · ${lessonsLabel} · ${formatPrice(d.price_amount, d.price_currency, locale)}`;
}

// Подготовка данных для Pricing TierCard'ов. Вынесено в frontmatter
// потому что zod-inferred type для features (z.record) внутри JSX
// требует cast'а, а TypeScript inside Astro template плохо обрабатывает
// inline cast generics — путает `<` с JSX tag.
interface TierCardProps {
  slug: string;
  featured: boolean;
  badge?: string;
  name: string;
  price: string;
  sub: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
}
// Instructor cards (Stage 9): для каждого id из sections.instructors.ids
// резолвим entry из коллекции `instructors`. Гарантированный порядок ids.
type InstructorEntry = CollectionEntry<"instructors">;
const allInstructors = await getCollection("instructors");
const instructorEntries: InstructorEntry[] = [];
// sections.instructors.ids доступен через type cast — sections типа any-like
const sectionInstructorIds = (sections as unknown as { instructors?: { ids?: string[] } }).instructors?.ids ?? [];
for (const id of sectionInstructorIds) {
  const entry = allInstructors.find((e: InstructorEntry) => e.id === `${id}.${typedLocale}`);
  if (entry) instructorEntries.push(entry);
}

const pricingCards: TierCardProps[] = programmeCards.map((p) => {
  const slug = p.id.replace(`.${typedLocale}`, "");
  const featured = slug === "bundle";
  const featuresObj = p.data.features as Record<string, FeatureValue>;
  return {
    slug,
    featured,
    badge: featured
      ? (typedLocale === "ru" ? "Лучшая цена" : "Best value")
      : undefined,
    name: p.data.title,
    price: formatPrice(p.data.price_amount, p.data.price_currency, typedLocale),
    sub: programmeMeta(p, typedLocale),
    features: programmeFeaturesToList(featuresObj, typedLocale),
    ctaText: p.data.marketing.cta_label,
    ctaHref: `/${typedLocale}/programmes/${slug}`,
  };
});

// UI-строки, не привязанные к данным коллекций. Когда появится
// общий dictionary (Stage 7 translation-pair validator + i18n
// helpers), переедет туда.
const ui = typedLocale === "ru"
  ? {
      explore: (title: string) => `Узнать про ${title}`,
      pendingStage9: "Карточки появятся в Stage 9 — данные подключаются из коллекций.",
      faqHeading: "Вопросы и ответы",
      levelLabel: (i: number) => `Уровень ${String(i + 1).padStart(2, "0")}`,
    }
  : {
      explore: (title: string) => `Explore ${title}`,
      pendingStage9: "Cards will appear in Stage 9 — data wired from collections.",
      faqHeading: "Common questions",
      levelLabel: (i: number) => `Level ${String(i + 1).padStart(2, "0")}`,
    };
---

<Layout locale={typedLocale} seo={seo}>
  <Fragment slot="schema">
    <OrganizationSchema locale={typedLocale} />
    <FaqSchema items={faqs} />
    {pricingCards.map((c) => {
      const programme = programmeCards.find((p) => p.id === `${c.slug}.${typedLocale}`);
      if (!programme) return null;
      const level = c.slug === "beginner"
        ? "Beginner"
        : c.slug === "intermediate"
        ? "Intermediate"
        : c.slug === "bundle"
        ? "All levels"
        : undefined;
      const hasPrice = programme.data.price_amount > 0;
      return (
        <CourseSchema
          slug={c.slug}
          locale={typedLocale}
          name={programme.data.title}
          description={programme.data.summary}
          educationalLevel={level}
          url={c.ctaHref}
          offer={hasPrice
            ? {
                price: Math.round(programme.data.price_amount / 100),
                priceCurrency: programme.data.price_currency,
              }
            : undefined}
        />
      );
    })}
    {instructorEntries.map((entry: InstructorEntry) => {
      const slug = entry.id.replace(`.${typedLocale}`, "");
      return (
        <PersonSchema
          slug={slug}
          locale={typedLocale}
          name={entry.data.name}
          jobTitle={entry.data.role}
          description={entry.data.bio_short}
          sameAs={entry.data.social ? Object.values(entry.data.social) : undefined}
        />
      );
    })}
  </Fragment>
  <Hero
    eyebrow={sections.hero.eyebrow}
    title={sections.hero.title}
    lede={sections.hero.lede}
    ctaText={sections.hero.cta_text}
    ctaHref={sections.hero.cta_href}
    cohortUrgency={sections.hero.cohort_urgency}
    locale={typedLocale}
    bgImage={heroBgImage}
  />

  <PromoStrip plates={heroPlates} locale={typedLocale} />

  <StatsBanner items={sections.stats.items} />

  <section class="section center" aria-labelledby="who-title">
    <div class="editorial-layout">
      <header class="editorial-layout__head section__head">
        <p class="eyebrow">{sections.who.eyebrow}</p>
        <h2 id="who-title" class="h2" set:html={sections.who.title}></h2>
      </header>
      <div class="editorial-layout__body who-grid">
        {sections.who.audiences.map((a, i) => (
          <WhoCard num={i + 1} title={a.title} body={a.body} />
        ))}
      </div>
    </div>
  </section>

  {behindCameraSection && behindCameraPhotos.length > 0 && (
    <PhotoStrip
      label={behindCameraSection.label}
      labelTone={behindCameraSection.tone}
      cols={behindCameraSection.cols}
      photos={behindCameraPhotos}
    />
  )}

  <section class="section center" aria-labelledby="curriculum-title">
    <header class="editorial-header-split">
      <div>
        <p class="eyebrow">{sections.curriculum.eyebrow}</p>
        <h2 id="curriculum-title" class="h2">{sections.curriculum.title}</h2>
      </div>
      <p class="text-muted">{sections.curriculum.intro}</p>
    </header>
    <div class="programme-grid">
      {programmeCards.map((p) => (
        <ProgrammeCard
          label={p.data.marketing.tagline}
          title={p.data.title}
          lede={p.data.summary}
          meta={programmeMeta(p, typedLocale)}
          linkHref={`/${typedLocale}/programmes/${p.id.replace(`.${typedLocale}`, "")}`}
          linkText={ui.explore(p.data.title)}
        />
      ))}
    </div>
  </section>

  <section class="section center" aria-labelledby="included-title">
    <header class="section__head">
      <p class="eyebrow">{sections.included.eyebrow}</p>
      <h2 id="included-title" class="h2">{sections.included.title}</h2>
    </header>
    <ul class="features-grid">
      {sections.included.items.map((item, i) => (
        <FeatureItem num={i + 1} title={item.title} body={item.body} />
      ))}
    </ul>
  </section>

  {/* Instructors (Stage 9): рендерится из коллекции `instructors`.
      Bios — DRAFT, реальные подменяются методистом без code change. */}
  <section class="section center" aria-labelledby="instructors-title">
    <header class="section__head">
      <p class="eyebrow">{sections.instructors.eyebrow}</p>
      <h2 id="instructors-title" class="h2" set:html={sections.instructors.title}></h2>
    </header>
    {instructorEntries.length > 0 ? (
      <div class="instructors-grid">
        {instructorEntries.map((entry: InstructorEntry) => (
          <InstructorCard
            name={entry.data.name}
            role={entry.data.role}
            body={entry.data.bio_short ?? ""}
          />
        ))}
      </div>
    ) : (
      <p class="text-faint">{ui.pendingStage9}</p>
    )}
  </section>

  {fromOurFilmsSection && fromOurFilmsPhotos.length > 0 && (
    <PhotoStrip
      label={fromOurFilmsSection.label}
      labelTone={fromOurFilmsSection.tone}
      cols={fromOurFilmsSection.cols}
      photos={fromOurFilmsPhotos}
    />
  )}

  <section class="section center" aria-labelledby="after-title">
    <header class="section__head">
      <p class="eyebrow">{sections.after.eyebrow}</p>
      <h2 id="after-title" class="h2" set:html={sections.after.title}></h2>
      <p class="text-muted">{sections.after.intro}</p>
    </header>
    <ul class="outcomes-grid">
      {sections.after.items.map((item) => (
        <OutcomeItem title={item.title} body={item.body} />
      ))}
    </ul>
  </section>

  {/* Pricing — TierCard'ы из programmes коллекции. Порядок тот же
      что в curriculum-секции (cardOrder), bundle получает featured-stamp
      как акцентный вариант. Stage 9. */}
  <section class="section center" aria-labelledby="pricing-title">
    <header class="section__head">
      <p class="eyebrow">{sections.pricing.eyebrow}</p>
      <h2 id="pricing-title" class="h2">{sections.pricing.title}</h2>
    </header>
    <div class="pricing-grid">
      {pricingCards.map((c) => (
        <TierCard
          badge={c.badge}
          name={c.name}
          price={c.price}
          sub={c.sub}
          features={c.features}
          ctaText={c.ctaText}
          ctaHref={c.ctaHref}
          featured={c.featured}
        />
      ))}
    </div>
  </section>

  {/* Slim banner — компонент сам по себе <section> (Stage 24h). */}
  <AiModule
    badge={sections.ai_module.badge}
    title={sections.ai_module.title}
    body={sections.ai_module.body}
    ctaText={sections.ai_module.cta_text}
    ctaHref={sections.ai_module.cta_href}
  />

  {faqs.length > 0 && (
    <section class="section center" aria-labelledby="faq-title">
      <div class="editorial-layout">
        <header class="editorial-layout__head section__head">
          <h2 id="faq-title" class="h2">{ui.faqHeading}</h2>
        </header>
        <div class="editorial-layout__body">
          <Faq items={faqs} />
        </div>
      </div>
    </section>
  )}

  <FinalCta
    eyebrow={sections.final_cta.eyebrow}
    title={sections.final_cta.title}
    body={sections.final_cta.body}
    ctaText={sections.final_cta.cta_text}
    ctaHref={sections.final_cta.cta_href}
    urgency={sections.final_cta.urgency}
  />
</Layout>
