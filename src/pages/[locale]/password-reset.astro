---
/*
 * /{locale}/password-reset — два режима в одной странице:
 *   - без ?token  → request mode (поле email → /api/auth/password-reset/request)
 *   - с  ?token=… → confirm mode (поле new password → /api/auth/password-reset/confirm)
 *
 * SSR (нужен TURNSTILE_SITE_KEY для request mode).
 */

import Layout from "../../layouts/public/Layout.astro";
import Btn from "../../components/public/Btn.astro";
import TurnstileWidget from "../../components/public/TurnstileWidget.astro";

export const prerender = false;

const { locale } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  return Astro.redirect("/en/password-reset");
}

const token = Astro.url.searchParams.get("token");
const stage = Astro.url.searchParams.get("stage");        // "sent" / "done"
const error = Astro.url.searchParams.get("error");

const t = locale === "ru"
  ? {
      eyebrow: "Сброс пароля",
      // request mode
      titleRequest: "Восстановите доступ.",
      ledeRequest: "Введите email — пришлём ссылку для сброса. Если такого email нет — ничего не произойдёт.",
      emailLabel: "Email",
      submitRequest: "Отправить ссылку",
      sentMessage: "Если email зарегистрирован, ссылка отправлена. Проверьте inbox и спам.",
      // confirm mode
      titleConfirm: "Новый пароль.",
      ledeConfirm: "Минимум 10 символов.",
      passwordLabel: "Пароль",
      submitConfirm: "Сохранить",
      doneMessage: "Пароль обновлён. Войдите со новым паролем.",
      goLogin: "Перейти на страницу входа",
      seo: { title: "Сброс пароля — MoiraiOnline", description: "Восстановите доступ к аккаунту MoiraiOnline." },
      errors: {
        invalid_token: "Ссылка недействительна или истекла. Запросите новую.",
        too_short: "Пароль слишком короткий — минимум 10 символов.",
        too_long: "Пароль слишком длинный — максимум 128 символов.",
        too_common: "Пароль слишком распространённый. Выберите менее предсказуемый.",
        rate_limited: "Слишком много попыток. Подождите час.",
        turnstile_failed: "Не удалось пройти проверку. Перезагрузите страницу.",
      } as Record<string, string>,
    }
  : {
      eyebrow: "Password reset",
      titleRequest: "Recover your access.",
      ledeRequest: "Enter your email and we'll send a reset link. No email exists in our system — nothing happens.",
      emailLabel: "Email",
      submitRequest: "Send link",
      sentMessage: "If the email is registered, a reset link was sent. Check inbox and spam.",
      titleConfirm: "Set a new password.",
      ledeConfirm: "Minimum 10 characters.",
      passwordLabel: "Password",
      submitConfirm: "Save",
      doneMessage: "Password updated. Sign in with your new password.",
      goLogin: "Go to sign in",
      seo: { title: "Password reset — MoiraiOnline", description: "Reset your MoiraiOnline password." },
      errors: {
        invalid_token: "The link is invalid or expired. Request a new one.",
        too_short: "Password too short — minimum 10 characters.",
        too_long: "Password too long — maximum 128 characters.",
        too_common: "Password too common. Choose something less guessable.",
        rate_limited: "Too many attempts. Please wait an hour.",
        turnstile_failed: "Verification failed. Reload and try again.",
      } as Record<string, string>,
    };

const errorMessage = error && t.errors[error] ? t.errors[error] : null;
const mode = token ? "confirm" : "request";
---

<Layout
  locale={locale}
  seo={{ title: t.seo.title, description: t.seo.description, noindex: true }}
>
  <section class="section center" aria-labelledby="reset-title">
    <header class="section__head">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1 id="reset-title" class="h1">
        {mode === "request" ? t.titleRequest : t.titleConfirm}
      </h1>
      <p class="text-muted">
        {mode === "request" ? t.ledeRequest : t.ledeConfirm}
      </p>
    </header>

    {stage === "sent" && (
      <div class="form" role="status">
        <p class="form__hint" style="text-align:center;">{t.sentMessage}</p>
      </div>
    )}

    {stage === "done" && (
      <div class="form" role="status">
        <p class="form__hint" style="text-align:center;">{t.doneMessage}</p>
        <Btn href={`/${locale}/login`} variant="primary" size="lg" arrow>{t.goLogin}</Btn>
      </div>
    )}

    {stage !== "sent" && stage !== "done" && mode === "request" && (
      <form class="form" id="reset-request" method="POST" action="/api/auth/password-reset/request" novalidate>
        <input type="hidden" name="locale" value={locale} />

        {errorMessage && <div class="form__error" role="alert">{errorMessage}</div>}

        <div class="form__field">
          <label class="form__label" for="reset-email">{t.emailLabel}</label>
          <input class="form__input" type="email" id="reset-email" name="email" autocomplete="email" required />
        </div>

        <TurnstileWidget />

        <Btn type="submit" variant="primary" size="lg" arrow>{t.submitRequest}</Btn>
      </form>
    )}

    {stage !== "sent" && stage !== "done" && mode === "confirm" && (
      <form class="form" id="reset-confirm" method="POST" action="/api/auth/password-reset/confirm" novalidate>
        <input type="hidden" name="token" value={token} />

        {errorMessage && <div class="form__error" role="alert">{errorMessage}</div>}

        <div class="form__field">
          <label class="form__label" for="reset-password">{t.passwordLabel}</label>
          <input class="form__input" type="password" id="reset-password" name="password"
                 autocomplete="new-password" minlength="10" required />
        </div>

        <Btn type="submit" variant="primary" size="lg" arrow>{t.submitConfirm}</Btn>
      </form>
    )}
  </section>
</Layout>

<script>
  // request mode submit
  const requestForm = document.getElementById("reset-request") as HTMLFormElement | null;
  if (requestForm) {
    requestForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!requestForm.reportValidity()) return;
      const fd = new FormData(requestForm);
      const email = fd.get("email");
      const locale = fd.get("locale");
      const turnstileToken = fd.get("cf-turnstile-response");

      if (!turnstileToken) {
        window.location.search = "?error=turnstile_failed";
        return;
      }

      const res = await fetch("/api/auth/password-reset/request", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, locale, turnstileToken }),
        credentials: "same-origin",
      });

      if (res.ok) {
        window.location.search = "?stage=sent";
        return;
      }
      let errCode = "rate_limited";
      try {
        const body = (await res.json()) as { error?: string };
        if (body.error) errCode = body.error;
      } catch { /* ignore */ }
      window.location.search = `?error=${encodeURIComponent(errCode)}`;
    });
  }

  // confirm mode submit
  const confirmForm = document.getElementById("reset-confirm") as HTMLFormElement | null;
  if (confirmForm) {
    confirmForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!confirmForm.reportValidity()) return;
      const fd = new FormData(confirmForm);
      const token = fd.get("token");
      const password = fd.get("password");

      const res = await fetch("/api/auth/password-reset/confirm", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token, password }),
        credentials: "same-origin",
      });

      if (res.ok) {
        // Drop the token from URL so back-navigation не показывает повторно
        window.location.search = "?stage=done";
        return;
      }

      let errCode = "invalid_token";
      try {
        const body = (await res.json()) as { error?: string };
        if (body.error) errCode = body.error;
      } catch { /* ignore */ }
      // Сохраняем token чтобы юзер мог исправить пароль (для weak_*)
      const tokenSafe = typeof token === "string" ? token : "";
      window.location.search = `?token=${encodeURIComponent(tokenSafe)}&error=${encodeURIComponent(errCode)}`;
    });
  }
</script>
