---
/*
 * /{locale}/account — приватная страница, требует валидную refresh-сессию.
 *
 * SSR + auth-guard: читаем refresh cookie → verifyRefreshSession →
 * findUserById + getUserAuthMethods → рендерим, либо redirect на login.
 *
 * Управление методами входа:
 *   - Если нет password method → форма "Set password" (POST set-password)
 *   - У каждого method'a (кроме когда он единственный) → кнопка Unlink (POST unlink)
 *   - Sign out — POST logout
 */

import DashboardLayout from "../../layouts/dashboard/Layout.astro";
import InstructorLayout from "../../layouts/instructor/Layout.astro";
import AdminLayout from "../../layouts/admin/Layout.astro";
import Btn from "../../components/public/Btn.astro";
import ConfirmModal from "../../components/shared/ConfirmModal.astro";
import { requireAuth, primaryRole } from "../../lib/server/guards";
import { getUserAuthMethods } from "../../lib/server/user-ops";

export const prerender = false;

const { locale } = Astro.params;
if (locale !== "en" && locale !== "ru") {
  return Astro.redirect("/en/account");
}

// allowDeactivated: deactivated user может управлять профилем (request reactivation)
const userOrRes = await requireAuth(Astro, { allowDeactivated: true });
if (userOrRes instanceof Response) return userOrRes;
const user = userOrRes;
const env = Astro.locals.runtime.env;

// Dynamic layout по primary role (decisions 2026-05-17 §7)
const primary = primaryRole(user.roles);
const Layout = primary === "admin"
  ? AdminLayout
  : primary === "instructor"
    ? InstructorLayout
    : DashboardLayout;

const methods = await getUserAuthMethods(env, user.id);
const hasPassword = methods.some((m) => m.kind === "password");
const canUnlink = methods.length > 1;

const verifiedBadge = Astro.url.searchParams.get("verified") === "1";

const t = locale === "ru"
  ? {
      eyebrow: "Личный кабинет",
      titleHi: (n: string | null) => n ? `Привет, ${n}.` : "Личный кабинет",
      emailLabel: "Почта",
      verified: "верифицирована",
      unverified: "не верифицирована",
      verifiedNote: "✅ Email подтверждён.",
      methodsTitle: "Способы входа",
      methodKindPassword: "Email + пароль",
      methodKindGoogle: "Google",
      methodKindDiscord: "Discord",
      addedOn: (ts: number) => `Добавлен ${new Date(ts * 1000).toLocaleDateString("ru")}`,
      signOut: "Выйти",
      refCode: "Реферальный код",
      setPasswordTitle: "Добавить пароль",
      setPasswordHint: "Сейчас вы входите только через социальную сеть. Можете добавить пароль как альтернативный способ.",
      passwordLabel: "Новый пароль",
      passwordHint: "Минимум 10 символов.",
      setPasswordSubmit: "Сохранить пароль",
      unlink: "Отвязать",
      lastMethodHint: "Это единственный способ входа. Чтобы отвязать — сначала добавьте другой.",
      seo: { title: "Личный кабинет — Moirai", description: "Управление аккаунтом Moirai." },
      errors: {
        too_short: "Пароль слишком короткий — минимум 10 символов.",
        too_long: "Пароль слишком длинный — максимум 128 символов.",
        too_common: "Пароль слишком распространённый.",
        password_already_set: "Пароль уже установлен. Для смены — используйте сброс пароля.",
        rate_limited: "Слишком много попыток. Подождите час.",
        cannot_unlink_last_method: "Это единственный способ входа — нельзя отвязать.",
        method_not_found: "Метод не найден.",
        unauthenticated: "Сессия истекла. Войдите заново.",
      } as Record<string, string>,
    }
  : {
      eyebrow: "Account",
      titleHi: (n: string | null) => n ? `Hi ${n}.` : "Account",
      emailLabel: "Email",
      verified: "verified",
      unverified: "not verified",
      verifiedNote: "✅ Email verified.",
      methodsTitle: "Sign-in methods",
      methodKindPassword: "Email + password",
      methodKindGoogle: "Google",
      methodKindDiscord: "Discord",
      addedOn: (ts: number) => `Added ${new Date(ts * 1000).toLocaleDateString("en")}`,
      signOut: "Sign out",
      refCode: "Referral code",
      setPasswordTitle: "Add a password",
      setPasswordHint: "You currently sign in only via social. You can add a password as an alternative.",
      passwordLabel: "New password",
      passwordHint: "Minimum 10 characters.",
      setPasswordSubmit: "Save password",
      unlink: "Unlink",
      lastMethodHint: "This is your only sign-in method. To unlink it — add another first.",
      seo: { title: "Account — Moirai", description: "Manage your Moirai account." },
      errors: {
        too_short: "Password too short — minimum 10 characters.",
        too_long: "Password too long — maximum 128 characters.",
        too_common: "Password is too common.",
        password_already_set: "Password already set. Use password reset to change it.",
        rate_limited: "Too many attempts. Please wait an hour.",
        cannot_unlink_last_method: "This is your only sign-in method — cannot unlink.",
        method_not_found: "Method not found.",
        unauthenticated: "Session expired. Sign in again.",
      } as Record<string, string>,
    };

function methodLabel(kind: string): string {
  if (kind === "password") return t.methodKindPassword;
  if (kind === "google") return t.methodKindGoogle;
  if (kind === "discord") return t.methodKindDiscord;
  return kind;
}
---

<Layout
  locale={locale}
  seo={{ title: t.seo.title, description: t.seo.description }}
  currentNavKey="account"
  userRoles={user.roles}
>
  <section class="section center" aria-labelledby="account-title">
    <header class="section__head">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1 id="account-title" class="h1">{t.titleHi(user.name)}</h1>
    </header>

    {verifiedBadge && (
      <div class="form" role="status">
        <p class="form__hint">{t.verifiedNote}</p>
      </div>
    )}

    <div class="form">
      <div class="form__field">
        <span class="form__label">{t.emailLabel}</span>
        <p class="text-muted">
          {user.email} —{" "}
          <span class={user.email_verified_at ? "text-accent" : "text-faint"}>
            {user.email_verified_at ? t.verified : t.unverified}
          </span>
        </p>
      </div>

      <div class="form__field">
        <span class="form__label">{t.refCode}</span>
        <p class="text-muted">{user.referral_code}</p>
      </div>

      <div class="form__field">
        <span class="form__label">{t.methodsTitle}</span>
        <ul class="form__hint" style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:var(--space-sm);">
          {methods.map((m) => (
            <li style="display:flex; align-items:center; justify-content:space-between; gap:var(--space-md);">
              <span>
                <strong style="color: var(--text);">{methodLabel(m.kind)}</strong>{" "}
                <span>· {t.addedOn(m.created_at)}</span>
              </span>
              {canUnlink ? (
                <button
                  type="button"
                  class="form__btn-inline js-unlink"
                  data-kind={m.kind}
                >{t.unlink}</button>
              ) : (
                <span class="text-faint" style="font-size: var(--type-body-sm);">
                  {t.lastMethodHint}
                </span>
              )}
            </li>
          ))}
        </ul>
        <div class="form__error js-methods-error" role="alert" hidden></div>
      </div>

      {!hasPassword && (
        <div class="form__field">
          <span class="form__label">{t.setPasswordTitle}</span>
          <p class="form__hint">{t.setPasswordHint}</p>
          <form id="set-password-form" method="POST" action="/api/auth/methods/set-password" novalidate>
            <div class="form__field">
              <label class="form__label" for="set-password-input">{t.passwordLabel}</label>
              <input
                class="form__input"
                type="password"
                id="set-password-input"
                name="password"
                autocomplete="new-password"
                minlength="10"
                required
              />
              <p class="form__hint">{t.passwordHint}</p>
            </div>
            <div class="form__error js-set-password-error" role="alert" hidden></div>
            <Btn type="submit" variant="primary" size="lg" arrow>{t.setPasswordSubmit}</Btn>
          </form>
        </div>
      )}

      <Btn type="button" variant="ghost" size="lg" class="js-signout">{t.signOut}</Btn>

      {/* Stage F: Notifications toggle + GDPR delete */}
      <div class="form__field">
        <span class="form__label">
          {locale === "ru" ? "Email-уведомления" : "Email notifications"}
        </span>
        <p class="form__hint">
          {locale === "ru" ? "Письма о фидбэке преподавателя." : "Receive emails about instructor feedback."}
        </p>
        <label style="display:flex; align-items:center; gap:var(--space-xs); cursor:pointer;">
          <input type="checkbox" id="notifications-toggle"
                 checked={user.notifications_email !== 0} />
          <span>{locale === "ru" ? "Включены" : "Enabled"}</span>
        </label>
        <p class="form__hint js-notifications-status" hidden></p>
      </div>

      {/* Instructor LK v2 Q9: daily digest opt-in (только для instructor роли) */}
      {user.roles.has("instructor") && (
        <div class="form__field">
          <span class="form__label">
            {locale === "ru" ? "Утренний digest preподa" : "Daily instructor digest"}
          </span>
          <p class="form__hint">
            {locale === "ru"
              ? "Утреннее письмо со сводкой: pending на проверке, late submissions, сегодняшние занятия."
              : "Morning email: pending submissions, late ones, today's sessions."}
          </p>
          <label style="display:flex; align-items:center; gap:var(--space-xs); cursor:pointer;">
            <input type="checkbox" id="digest-toggle"
                   checked={user.instructor_digest_opt_in !== 0} />
            <span>{locale === "ru" ? "Включён" : "Enabled"}</span>
          </label>
          <p class="form__hint js-digest-status" hidden></p>
        </div>
      )}

      <div class="form__field" style="border-top: 1px solid var(--border); padding-top: var(--space-lg); margin-top: var(--space-md);">
        <span class="form__label" style="color: var(--text-accent);">
          {locale === "ru" ? "Удалить аккаунт" : "Delete account"}
        </span>
        <p class="form__hint">
          {locale === "ru"
            ? "Удалит все ваши данные навсегда. Это действие необратимо."
            : "This will delete all your data permanently. Cannot be undone."}
        </p>
        <Btn type="button" variant="ghost" size="default" class="js-delete-account">
          {locale === "ru" ? "Удалить мои данные навсегда" : "Delete my data permanently"}
        </Btn>
      </div>
    </div>
  </section>

  <ConfirmModal
    id="delete-account-modal"
    title={locale === "ru" ? "Удалить аккаунт?" : "Delete account?"}
    body={locale === "ru"
      ? "Это действие необратимо. Введите DELETE для подтверждения."
      : "This action cannot be undone. Type DELETE to confirm."}
    mode="typing"
    confirmCode="DELETE"
    typingHint={locale === "ru" ? "Введите DELETE для подтверждения" : "Type DELETE to confirm"}
    confirmLabel={locale === "ru" ? "Удалить навсегда" : "Delete permanently"}
    cancelLabel={locale === "ru" ? "Отмена" : "Cancel"}
    danger={true}
  />
</Layout>

<style>
  .form__btn-inline {
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: var(--type-micro-md);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 6px 14px;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }
  .form__btn-inline:hover {
    color: var(--amber);
    border-color: var(--amber);
  }
</style>

<script define:vars={{ errMap: t.errors }}>
  function showInlineError(selector, code) {
    const el = document.querySelector(selector);
    if (!el) return;
    el.textContent = errMap[code] ?? code;
    el.hidden = false;
  }
  function hideInlineError(selector) {
    const el = document.querySelector(selector);
    if (el) el.hidden = true;
  }

  // Sign out
  document.querySelectorAll(".js-signout").forEach((btn) => {
    btn.addEventListener("click", async () => {
      await fetch("/api/auth/logout", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
      });
      sessionStorage.removeItem("moirai_access_token");
      const path = window.location.pathname;
      const m = /^\/(en|ru)\//.exec(path);
      const loc = m ? m[1] : "en";
      window.location.href = `/${loc}/`;
    });
  });

  // Set password
  const setForm = document.getElementById("set-password-form");
  if (setForm) {
    setForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!setForm.reportValidity()) return;
      hideInlineError(".js-set-password-error");
      const fd = new FormData(setForm);
      const res = await fetch("/api/auth/methods/set-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify({ password: fd.get("password") }),
      });
      if (res.ok) {
        // Reload — server-side rerender уберёт форму, покажет password в списке
        window.location.reload();
        return;
      }
      let code = "invalid_input";
      try {
        const body = await res.json();
        if (body.error) code = body.error;
      } catch { /* ignore */ }
      showInlineError(".js-set-password-error", code);
    });
  }

  // Stage F: Notifications toggle
  const notifToggle = document.getElementById("notifications-toggle");
  const notifStatus = document.querySelector(".js-notifications-status");
  if (notifToggle && notifToggle instanceof HTMLInputElement) {
    notifToggle.addEventListener("change", async () => {
      const enabled = notifToggle.checked;
      try {
        const res = await fetch("/api/account/notifications-toggle", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ enabled }),
        });
        if (!res.ok) throw new Error("toggle_failed");
        if (notifStatus instanceof HTMLElement) {
          notifStatus.textContent = "Saved";
          notifStatus.hidden = false;
          setTimeout(() => { notifStatus.hidden = true; }, 2000);
        }
      } catch (err) {
        console.error("[notifications-toggle]", err);
        notifToggle.checked = !enabled; // revert
      }
    });
  }

  // Instructor LK v2 Q9: Daily digest toggle
  const digestToggle = document.getElementById("digest-toggle");
  const digestStatus = document.querySelector(".js-digest-status");
  if (digestToggle && digestToggle instanceof HTMLInputElement) {
    digestToggle.addEventListener("change", async () => {
      const enabled = digestToggle.checked;
      try {
        const res = await fetch("/api/account/digest-toggle", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ enabled }),
        });
        if (!res.ok) throw new Error("toggle_failed");
        if (digestStatus instanceof HTMLElement) {
          digestStatus.textContent = "Saved";
          digestStatus.hidden = false;
          setTimeout(() => { digestStatus.hidden = true; }, 2000);
        }
      } catch (err) {
        console.error("[digest-toggle]", err);
        digestToggle.checked = !enabled;
      }
    });
  }

  // Stage F: GDPR delete account
  document.querySelectorAll(".js-delete-account").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (typeof window.openConfirmModal !== "function") return;
      window.openConfirmModal("delete-account-modal", async () => {
        const res = await fetch("/api/account/delete", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ confirmation: "DELETE" }),
        });
        if (res.ok) {
          window.location.href = "/";
        } else {
          alert("Delete failed. Please try again.");
        }
      });
    });
  });

  // Unlink
  document.querySelectorAll(".js-unlink").forEach((btn) => {
    btn.addEventListener("click", async () => {
      hideInlineError(".js-methods-error");
      const kind = btn.dataset.kind;
      if (!kind) return;
      const res = await fetch("/api/auth/methods/unlink", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify({ kind }),
      });
      if (res.ok) {
        window.location.reload();
        return;
      }
      let code = "invalid_input";
      try {
        const body = await res.json();
        if (body.error) code = body.error;
      } catch { /* ignore */ }
      showInlineError(".js-methods-error", code);
    });
  });
</script>
